Cell[CellGroupData[{

Cell["Magnetic Fields ", "Section",
 CellChangeTimes->{{3.981547685201488*^9, 3.981547687520939*^9}, {
   3.98154877479456*^9, 3.981548778633245*^9}, 3.981548933138051*^9, {
   3.98154994258657*^9, 
   3.981549944674758*^9}},ExpressionUUID->"3a0ffbd2-63ba-4cb6-8534-\
4239196356c5"],

Cell[CellGroupData[{

Cell["Larmor Rotation", "Subsection",
 CellChangeTimes->{{3.98154893466994*^9, 
  3.981548936408955*^9}},ExpressionUUID->"cd0de21f-ae5f-41a5-bcbb-\
758623a5520f"],

Cell["\<\
Doing the same for a magnetic-only field at paraxial order yields a less \
familiar result:\
\>", "Text",
 CellChangeTimes->{{3.9815458521029997`*^9, 
  3.981545882816751*^9}},ExpressionUUID->"a172d150-abd0-48ae-8f7d-\
7c0288bddd0a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"equationsOfMotion", "[", 
    RowBox[{"\[Phi]0", ",", "\[Eta]", ",", "1"}], "]"}], "[", 
   RowBox[{
    RowBox[{"0", "&"}], ",", "B"}], "]"}], "//", "Expand"}]], "Input",
 CellChangeTimes->{{3.981545886176577*^9, 3.981545889713431*^9}, {
  3.981546196888085*^9, 3.9815462125773*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"4ccd7157-8c98-4054-ac45-70b5eca48348"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["x", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "z", "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"\[Eta]", " ", 
        RowBox[{"y", "[", "z", "]"}], " ", 
        RowBox[{
         SuperscriptBox["B", "\[Prime]",
          MultilineFunction->None], "[", "z", "]"}]}], 
       RowBox[{"2", " ", 
        SqrtBox["\[Phi]0"]}]]}], "-", 
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       RowBox[{"B", "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["y", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      SqrtBox["\[Phi]0"]], "+", 
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       SuperscriptBox[
        RowBox[{"x", "[", "z", "]"}], "2"], " ", 
       RowBox[{
        SuperscriptBox["y", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["B", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"4", " ", 
       SqrtBox["\[Phi]0"]}]], "+", 
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       SuperscriptBox[
        RowBox[{"y", "[", "z", "]"}], "2"], " ", 
       RowBox[{
        SuperscriptBox["y", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["B", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"4", " ", 
       SqrtBox["\[Phi]0"]}]]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["y", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "z", "]"}], "\[Equal]", 
    RowBox[{
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       RowBox[{"x", "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["B", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"2", " ", 
       SqrtBox["\[Phi]0"]}]], "+", 
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       RowBox[{"B", "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["x", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      SqrtBox["\[Phi]0"]], "-", 
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       SuperscriptBox[
        RowBox[{"x", "[", "z", "]"}], "2"], " ", 
       RowBox[{
        SuperscriptBox["x", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["B", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"4", " ", 
       SqrtBox["\[Phi]0"]}]], "-", 
     FractionBox[
      RowBox[{"\[Eta]", " ", 
       SuperscriptBox[
        RowBox[{"y", "[", "z", "]"}], "2"], " ", 
       RowBox[{
        SuperscriptBox["x", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["B", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"4", " ", 
       SqrtBox["\[Phi]0"]}]]}]}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.981545890674263*^9, {3.98154619751653*^9, 3.981546213021503*^9}, 
   3.981547508400466*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"f8184562-c8b9-4450-929b-18eb93ce7855"]
}, Open  ]],

Cell[TextData[{
 "This is precisely because the axisymmetric version replaced the coupling \
effect of the Larmor rotation by an effective radial restoring force \
proportional to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["B", "TI"], 
        StyleBox["z", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "B_z^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b14a4c86-fb64-4a52-9132-a3a1ac09a385"],
 " .\n\nLet\[CloseCurlyQuote]s quickly derive where this comes from. Our \
starting point will be the above equations w/o the cubic terms:\n\n\t",
 Cell[BoxData[
  FormBox[Cell[BoxData[
    FormBox[GridBox[{
       {Cell[TextData[{
         " ",
         Cell[BoxData[
          FormBox[
           StyleBox[
            SuperscriptBox[
             StyleBox["x", "TI"], "\[Prime]\[Prime]"], "DisplayFormula"], 
           TraditionalForm]],ExpressionUUID->
          "2934ae04-ab0b-4809-98de-9035d871b64c"],
         " "
        }],ExpressionUUID->"d156e5dd-c869-4824-be0d-5162ab50b187"], Cell[
        TextData[{
         " ",
         Cell[BoxData[
          FormBox[
           StyleBox[
            RowBox[{"\[LongEqual]", "-", 
             FractionBox["\[Eta]", 
              SqrtBox[
               SubscriptBox["\[CapitalPhi]", "0"]]], 
             StyleBox["B", "TI"], 
             RowBox[{"(", 
              StyleBox["z", "TI"], ")"}], " ", 
             SuperscriptBox[
              StyleBox["y", "TI"], "\[Prime]"], "-", 
             FractionBox["\[Eta]", 
              RowBox[{"2", 
               SqrtBox[
                SubscriptBox["\[CapitalPhi]", "0"]]}]], 
             StyleBox["y", "TI"], " ", 
             SuperscriptBox[
              StyleBox["B", "TI"], "\[Prime]"], 
             RowBox[{"(", 
              StyleBox["z", "TI"], ")"}], ","}], "DisplayFormula"], 
           TraditionalForm]],ExpressionUUID->
          "b262f3f9-c43a-44db-8ba1-db061fdfcaf6"],
         " "
        }],ExpressionUUID->"b173cc98-6298-474e-8f43-1035b9fb10c7"]},
       {Cell[TextData[{
         " ",
         Cell[BoxData[
          FormBox[
           StyleBox[
            SuperscriptBox[
             StyleBox["y", "TI"], "\[Prime]\[Prime]"], "DisplayFormula"], 
           TraditionalForm]],ExpressionUUID->
          "eebc0791-8c79-414e-9ed7-2328bc614480"],
         " "
        }],ExpressionUUID->"596dff65-c0a1-44ff-8654-2488ade02ae8"], Cell[
        TextData[{
         " ",
         Cell[BoxData[
          FormBox[
           StyleBox[
            RowBox[{"\[LongEqual]", 
             FractionBox["\[Eta]", 
              SqrtBox[
               SubscriptBox["\[CapitalPhi]", "0"]]], 
             StyleBox["B", "TI"], 
             RowBox[{"(", 
              StyleBox["z", "TI"], ")"}], " ", 
             SuperscriptBox[
              StyleBox["x", "TI"], "\[Prime]"], "+", 
             FractionBox["\[Eta]", 
              RowBox[{"2", 
               SqrtBox[
                SubscriptBox["\[CapitalPhi]", "0"]]}]], 
             StyleBox["x", "TI"], " ", 
             SuperscriptBox[
              StyleBox["B", "TI"], "\[Prime]"], 
             RowBox[{"(", 
              StyleBox["z", "TI"], ")"}], "."}], "DisplayFormula"], 
           TraditionalForm]],ExpressionUUID->
          "3a3e2bbe-3d3b-47f2-ba67-e00de5aa2670"],
         " "
        }],ExpressionUUID->"cf307c68-573c-4bb9-86bd-a62ac1c14752"]}
      }], TraditionalForm]],ExpressionUUID->
    "7451fe05-a4e2-4643-8db9-dae24e7c1dc7"], TraditionalForm]],ExpressionUUID->
  "18e34268-ee82-4c3e-8ab6-880d9c84e424"]
}], "Text",
 CellChangeTimes->{
  3.981547585690291*^9},ExpressionUUID->"7b5d9ad2-9a86-4682-9a7f-\
695ffba095e9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"larmorFrequency", "[", "z_", "]"}], ":=", 
   RowBox[{"\[Eta]", " ", 
    RowBox[{
     RowBox[{"B", "[", "z", "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", 
       RowBox[{"Sqrt", "[", "\[CapitalPhi]0", "]"}]}], ")"}]}]}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"paraxialEqnX", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "''"}], "[", "z", "]"}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "2"}], " ", 
      RowBox[{"larmorFrequency", "[", "z", "]"}], " ", 
      RowBox[{
       RowBox[{"y", "'"}], "[", "z", "]"}]}], "-", 
     RowBox[{
      RowBox[{
       RowBox[{"larmorFrequency", "'"}], "[", "z", "]"}], " ", 
      RowBox[{"y", "[", "z", "]"}]}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"paraxialEqnY", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"y", "''"}], "[", "z", "]"}], "==", 
    RowBox[{
     RowBox[{"2", " ", 
      RowBox[{"larmorFrequency", "[", "z", "]"}], " ", 
      RowBox[{
       RowBox[{"x", "'"}], "[", "z", "]"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"larmorFrequency", "'"}], "[", "z", "]"}], " ", 
      RowBox[{"x", "[", "z", "]"}]}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.981547606203142*^9, 3.9815476671733503`*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"f58a3177-cf6e-4c63-a2b2-df484055fae7"],

Cell[TextData[{
 "Next, we will combine the equations into a single complex-valued equation \
(where rotation is more naturally expressed), using a dummy variable:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["u", "TI"], "(", 
     StyleBox["z", "TI"], ")"}], "\[LongEqual]", 
    RowBox[{
     RowBox[{
      StyleBox["x", "TI"], "(", 
      StyleBox["z", "TI"], ")"}], "+", 
     RowBox[{
      StyleBox["i", "TI"], 
      RowBox[{
       RowBox[{
        StyleBox["y", "TI"], "(", 
        StyleBox["z", "TI"], ")"}], "."}]}]}]}], TraditionalForm]],
  ExpressionUUID->"18f698d9-c075-494a-a402-76bbf0f7e06a"]
}], "Text",
 CellChangeTimes->{{3.981547679393154*^9, 3.9815477375651608`*^9}, {
  3.981547867345066*^9, 
  3.9815478705448093`*^9}},ExpressionUUID->"a5d3fb9a-10d2-4674-a671-\
20c0497ad961"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"complexVariable", "[", "z_", "]"}], ":=", 
   RowBox[{
    RowBox[{"x", "[", "z", "]"}], "+", 
    RowBox[{"I", " ", 
     RowBox[{"y", "[", "z", "]"}]}]}]}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"complexVariablePrime", "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"complexVariable", "[", "z", "]"}], ",", "z"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"complexVariableDoublePrime", "=", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"complexVariable", "[", "z", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"complexEquation", "=", 
  RowBox[{
   RowBox[{"complexVariableDoublePrime", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "''"}], "[", "z", "]"}], "->", 
       RowBox[{"paraxialEqnX", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "''"}], "[", "z", "]"}], "->", 
       RowBox[{"paraxialEqnY", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], "//", 
   "Simplify"}]}]}], "Input",
 CellChangeTimes->{{3.9815478238024683`*^9, 3.9815478257650423`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"11edcc47-f66b-4f2c-80bd-f51413ec3487"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", "\[Eta]", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "[", "z", "]"}], " ", 
      RowBox[{
       SuperscriptBox["B", "\[Prime]",
        MultilineFunction->None], "[", "z", "]"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"y", "[", "z", "]"}], " ", 
      RowBox[{
       SuperscriptBox["B", "\[Prime]",
        MultilineFunction->None], "[", "z", "]"}]}], "+", 
     RowBox[{"2", " ", 
      RowBox[{"B", "[", "z", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["x", "\[Prime]",
          MultilineFunction->None], "[", "z", "]"}], "+", 
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]",
           MultilineFunction->None], "[", "z", "]"}]}]}], ")"}]}]}], ")"}]}], 
  
  RowBox[{"2", " ", 
   SqrtBox["\[CapitalPhi]0"]}]]], "Output",
 CellChangeTimes->{{3.9815478096670322`*^9, 3.9815478260971737`*^9}},
 CellLabel->"Out[20]=",ExpressionUUID->"ac8848ec-bb71-463a-bfe1-5d048b752cb8"]
}, Open  ]],

Cell[TextData[{
 "This is identical to the following complex-valued ODE:\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["u", "TI"], "\[Prime]\[Prime]"], "\[LongEqual]", "2", 
         StyleBox["i", "TI"], "\[CapitalOmega]", 
         SuperscriptBox[
          StyleBox["u", "TI"], "\[Prime]"], "+", 
         StyleBox["i", "TI"], 
         SuperscriptBox["\[CapitalOmega]", "\[Prime]"], 
         StyleBox["u", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "u'' = 2 i \\Omega u' + i \\Omega' u", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8dc27a9b-4b45-477d-860d-d634b92785a3"],
 ",\nwith ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalOmega]", "\[LongEqual]", 
         FractionBox[
          RowBox[{"\[Eta]", 
            StyleBox["B", "TI"], 
            RowBox[{"[", 
              StyleBox["z", "TI"], "]"}]}], 
          RowBox[{"2", 
            SqrtBox[
             SubscriptBox["\[CapitalPhi]", "0"]]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\Omega=\\frac{\\eta B[z]}{2 \\sqrt{\\Phi_0}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6b59e821-7c19-4c24-baaf-aa68a97e3df2"],
 " being the Larmor frequency."
}], "Text",
 CellChangeTimes->{{3.9815478739775457`*^9, 
  3.9815480057042007`*^9}},ExpressionUUID->"c4f9f5c8-d5d8-445e-8ee4-\
fc8cd37750c6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"2", " ", "I", " ", 
    RowBox[{"larmorFrequency", "[", "z", "]"}], " ", "complexVariablePrime"}],
    "+", 
   RowBox[{"I", " ", 
    RowBox[{
     RowBox[{"larmorFrequency", "'"}], "[", "z", "]"}], " ", 
    RowBox[{"complexVariable", "[", "z", "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9815480396358356`*^9, 3.981548069125369*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"7e6d94e1-e51b-4423-ba89-d001915008e9"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", "\[Eta]", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "[", "z", "]"}], " ", 
      RowBox[{
       SuperscriptBox["B", "\[Prime]",
        MultilineFunction->None], "[", "z", "]"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"y", "[", "z", "]"}], " ", 
      RowBox[{
       SuperscriptBox["B", "\[Prime]",
        MultilineFunction->None], "[", "z", "]"}]}], "+", 
     RowBox[{"2", " ", 
      RowBox[{"B", "[", "z", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["x", "\[Prime]",
          MultilineFunction->None], "[", "z", "]"}], "+", 
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{
          SuperscriptBox["y", "\[Prime]",
           MultilineFunction->None], "[", "z", "]"}]}]}], ")"}]}]}], ")"}]}], 
  
  RowBox[{"2", " ", 
   SqrtBox["\[CapitalPhi]0"]}]]], "Output",
 CellChangeTimes->{{3.98154804100526*^9, 3.981548069346634*^9}},
 CellLabel->"Out[25]=",ExpressionUUID->"76f1ed75-6ae6-45e6-a58f-09c4da1d24ab"]
}, Open  ]],

Cell[TextData[{
 "Now, we can define the Larmor transformation and substitute into the ODE:\n\
\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Theta]", 
          StyleBox["z", "TI"]], "\[LongEqual]", "\[Integral]", 
         "\[CapitalOmega]", 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], 
         StyleBox["d", "TI"], 
         StyleBox["z", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta_z = \\int \\Omega(z) dz", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7b79ee1d-fcb7-481a-bfaa-fe925bac2e18"]
}], "Text",
 CellChangeTimes->{{3.9815480803936377`*^9, 3.981548103315011*^9}, 
   3.981548134920991*^9, {3.9815483182097063`*^9, 
   3.981548321391808*^9}},ExpressionUUID->"08696006-dd0b-46c1-bf70-\
2e9fe6db95de"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"larmorRotation", "[", "z_", "]"}], ":=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"larmorFrequency", "[", "z", "]"}], ",", "z"}], "]"}]}], "\n", 
 RowBox[{"complexSubstitution", "=", 
  RowBox[{
   RowBox[{"w", "[", "z", "]"}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{"I", " ", 
     RowBox[{"larmorRotation", "[", "z", "]"}]}], "]"}]}]}]}], "Input",
 CellChangeTimes->{3.981548172122085*^9},
 CellLabel->"In[26]:=",ExpressionUUID->"a6ee6da8-e51d-4a98-a904-544c75c1d0c6"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   FractionBox[
    RowBox[{"\[ImaginaryI]", " ", "\[Eta]", " ", 
     RowBox[{"\[Integral]", 
      RowBox[{
       RowBox[{"B", "[", "z", "]"}], 
       RowBox[{"\[DifferentialD]", "z"}]}]}]}], 
    RowBox[{"2", " ", 
     SqrtBox["\[CapitalPhi]0"]}]]], " ", 
  RowBox[{"w", "[", "z", "]"}]}]], "Output",
 CellChangeTimes->{3.981548172417179*^9},
 CellLabel->"Out[27]=",ExpressionUUID->"93a82dc4-8567-47ac-86fc-39189f3830bd"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"complexSubstitutionPrime", "=", 
   RowBox[{"D", "[", 
    RowBox[{"complexSubstitution", ",", "z"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"complexSubstitutionDoublePrime", "=", 
   RowBox[{"D", "[", 
    RowBox[{"complexSubstitution", ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"rotatedODE", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"complexSubstitutionDoublePrime", "-", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "I", " ", 
       RowBox[{"larmorFrequency", "[", "z", "]"}], " ", 
       "complexSubstitutionPrime"}], "+", 
      RowBox[{"I", " ", 
       RowBox[{
        RowBox[{"larmorFrequency", "'"}], "[", "z", "]"}], " ", 
       "complexSubstitution"}]}], ")"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.981548189965559*^9, 3.981548245386386*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"d9247dc4-83aa-4219-89f1-e2163e6ecefb"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", "\[Eta]", " ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        RowBox[{"B", "[", "z", "]"}], 
        RowBox[{"\[DifferentialD]", "z"}]}]}]}], 
     RowBox[{"2", " ", 
      SqrtBox["\[CapitalPhi]0"]}]]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Eta]", "2"], " ", 
      SuperscriptBox[
       RowBox[{"B", "[", "z", "]"}], "2"], " ", 
      RowBox[{"w", "[", "z", "]"}]}], "+", 
     RowBox[{"4", " ", "\[CapitalPhi]0", " ", 
      RowBox[{
       SuperscriptBox["w", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "z", "]"}]}]}], ")"}]}], 
  RowBox[{"4", " ", "\[CapitalPhi]0"}]]], "Output",
 CellChangeTimes->{3.9815482456365337`*^9},
 CellLabel->"Out[32]=",ExpressionUUID->"7a7d2e5f-3029-4814-98f1-07697c6ee462"]
}, Open  ]],

Cell[TextData[{
 "Since this is equal to zero, the term in the parentheses must also be zero \
-- which is precisely around paraxial ODE for magnetic fields.\nMagnetic \
lenses focus through Larmor rotation; in the rotating frame this appears as a \
quadratic restoring force proportional to  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["B", "TI"], 
        StyleBox["z", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "B_z^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2d504bbc-1505-4781-bd34-7bb485f5249c"],
 "."
}], "Text",
 CellChangeTimes->{{3.981548337449286*^9, 3.9815483750972424`*^9}, {
  3.9815484055241213`*^9, 
  3.981548426739161*^9}},ExpressionUUID->"6c03b4d5-9904-4646-991d-\
6851bbfae448"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Glaser Ray Tracing", "Subsection",
 CellChangeTimes->{{3.981548943706367*^9, 
  3.9815489516584167`*^9}},ExpressionUUID->"e3bfb3bf-1542-4eed-a299-\
cc39bb39ba2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"magneticField", "[", "\"\<glaser\>\"", "]"}], "[", 
     RowBox[{"a_", ",", "B0_"}], "]"}], "[", "z_", "]"}], "=", 
   RowBox[{"B0", "/", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["z", "a"], ")"}], "2"]}], ")"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellLabel->"In[16]:=",ExpressionUUID->"e1e895ef-0bcf-4ef5-ada0-6555f4df69fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"buildRayTracer", "[", 
   RowBox[{"\"\<glaser\>\"", ",", "order_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Phi]0", "=", "1000"}], ",", "\[IndentingNewLine]", 
      RowBox[{"a", "=", "0.0075"}], ",", "\[IndentingNewLine]", 
      RowBox[{"B0", "=", "0.01"}], ",", "\[IndentingNewLine]", 
      RowBox[{"z0", "=", 
       RowBox[{"-", "0.1"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"zf", "=", "0.1"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\[Eta]", "=", 
       RowBox[{"physicalConstants", "[", "\"\<\[Eta]\>\"", "]"}]}], ",", 
      "\[IndentingNewLine]", "Bfield", ",", "\[IndentingNewLine]", "eom"}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Bfield", "=", 
      RowBox[{
       RowBox[{"magneticField", "[", "\"\<glaser\>\"", "]"}], "[", 
       RowBox[{"a", ",", "B0"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"eom", "=", 
      RowBox[{
       RowBox[{"equationsOfMotion", "[", 
        RowBox[{"\[Phi]0", ",", "\[Eta]", ",", "order"}], "]"}], "[", 
       RowBox[{
        RowBox[{"0", "&"}], ",", "Bfield"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nonParaxialRayTracing", "[", 
      RowBox[{"eom", ",", 
       RowBox[{"{", 
        RowBox[{"z0", ",", "zf"}], "}"}], ",", 
       RowBox[{"MaxSteps", "->", "100000"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978578761150917*^9, 3.978578886941655*^9}, {
   3.9785790214613953`*^9, 3.97857907905379*^9}, 3.978595473804912*^9, {
   3.978685871493622*^9, 3.978685871548215*^9}, {3.978747953780222*^9, 
   3.9787479764785633`*^9}, {3.981548821337619*^9, 3.981548821529244*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"18692836-00e3-43fe-9e4f-38270c3f1fa2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rayTracer", "[", "\"\<glaser\>\"", "]"}], "=", 
   RowBox[{"buildRayTracer", "[", 
    RowBox[{"\"\<glaser\>\"", ",", "3"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nonParaxialRays", "[", "\"\<glaser\>\"", "]"}], "=", 
    RowBox[{"ParallelMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"rayTracer", "[", "\"\<glaser\>\"", "]"}], "@@", "#"}], "&"}],
       ",", 
      RowBox[{"coneOfRays", "[", "24", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"glaserRays", "=", 
  RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Evaluate", "@", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Prepend", "[", 
         RowBox[{
          RowBox[{"Through", "[", 
           RowBox[{"#", "[", "z", "]"}], "]"}], ",", "z"}], "]"}], "&"}], ",", 
       RowBox[{"nonParaxialRays", "[", "\"\<glaser\>\"", "]"}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", 
      RowBox[{"-", "0.1"}], ",", "0.1"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"BoxRatios", "->", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1"}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"RGBColor", "[", 
      RowBox[{"0", ",", "0.5", ",", "0"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.981548847221559*^9, 3.981548882385666*^9}, 
   3.981549011567152*^9},
 CellLabel->"In[43]:=",ExpressionUUID->"7b403ae5-fdc0-4a49-ac17-1864916e15e1"],

