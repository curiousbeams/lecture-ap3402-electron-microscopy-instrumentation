Notebook[{

Cell[CellGroupData[{
Cell["Physics of Electron Microscopy Instrumentation", "Title",
 CellChangeTimes->{{3.9814466515808773`*^9, 
  3.9814466605467*^9}},ExpressionUUID->"c9cf8592-a769-4a72-a83c-dcc2ee2e496c"],

Cell["Georgios Varnavides | March 2nd 2026", "Subtitle",
 CellChangeTimes->{{3.9814466652477837`*^9, 
  3.9814466774444857`*^9}},ExpressionUUID->"b50004b6-2de7-4c51-8d5c-\
ae02c3ef1e1f"],

Cell[CellGroupData[{

Cell["Non-Paraxial Ray Tracing", "Chapter",
 CellChangeTimes->{{3.981446681326468*^9, 3.9814466939325247`*^9}, {
  3.9815366436048727`*^9, 3.981536647029811*^9}, {3.981544630735242*^9, 
  3.981544636870346*^9}},ExpressionUUID->"a91c8cd3-59ac-4de5-8d59-\
36bc489e8e90"],

Cell[CellGroupData[{

Cell["Cartesian Laplace Field Expansions", "Section",
 CellChangeTimes->{{3.9815446682547207`*^9, 3.9815446755504837`*^9}, {
  3.981549404612167*^9, 
  3.9815494070344687`*^9}},ExpressionUUID->"c84f2989-6f16-43c6-bb2a-\
4a52800d69ae"],

Cell[TextData[{
 "So far, we have leveraged the cylindrical symmetry of round lenses to see \
how electrostatic and magnetic fields near the optic axis satisfying Laplace\
\[CloseCurlyQuote]s equation can be analytically expanded from axial fields, \
arriving at very simple paraxial equations. This captured most of the physics \
we care about for focusing, though notice we only indirectly investigated \
Larmor rotation in magnetic fields.\n\nTo go further, as well as introduce \
non-paraxial ray tracing, it\[CloseCurlyQuote]s pedagogical to switch to \
Cartesian 3D coordinates.\nFor an axisymmetric magnetic or electrostatic \
field with axial component ",
 Cell[BoxData[
  FormBox[
   RowBox[{"F", "(", "z", ")"}], TraditionalForm]],ExpressionUUID->
  "a4db6178-60c8-4340-b9ea-a59ca2ce2d1a"],
 " (either ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "z"], TraditionalForm]],ExpressionUUID->
  "45cdc656-1593-4813-a4c3-d2cc83d6b8d2"],
 " or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "z"], TraditionalForm]],ExpressionUUID->
  "8d78e6f0-7c44-45b0-8345-a3aa47d99c0e"],
 "), the Cartesian expansion satisfying Laplace\[CloseCurlyQuote]s equation \
is\n\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["z", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"], ",", 
             StyleBox["z", "TI"]}], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["n", "TI"], "\[LongEqual]", "0"}], 
          StyleBox["N", "TI"], LimitsPositioning -> True], 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", "-1", ")"}], 
           StyleBox["n", "TI"]], 
          RowBox[{
            SuperscriptBox["2", 
             RowBox[{"2", 
               StyleBox["n", "TI"]}]], 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{
                 StyleBox["n", "TI"], "!"}], ")"}], "2"]}]], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["x", "TI"], "2"], "+", 
              SuperscriptBox[
               StyleBox["y", "TI"], "2"]}], ")"}], 
          StyleBox["n", "TI"]], 
         SuperscriptBox[
          StyleBox["F", "TI"], 
          RowBox[{"(", 
            RowBox[{"2", 
              StyleBox["n", "TI"]}], ")"}]], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], ",", "\n", 
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["x", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"], ",", 
             StyleBox["z", "TI"]}], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["n", "TI"], "\[LongEqual]", "1"}], 
          StyleBox["N", "TI"], LimitsPositioning -> True], 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", "-1", ")"}], 
           StyleBox["n", "TI"]], 
          RowBox[{
            SuperscriptBox["2", 
             RowBox[{"2", 
               StyleBox["n", "TI"], "-", "1"}]], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["n", "TI"], "-", "1"}], ")"}], "!", 
            StyleBox["n", "TI"], "!"}]], 
         StyleBox["x", "TI"], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["x", "TI"], "2"], "+", 
              SuperscriptBox[
               StyleBox["y", "TI"], "2"]}], ")"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], 
         SuperscriptBox[
          StyleBox["F", "TI"], 
          RowBox[{"(", 
            RowBox[{"2", 
              StyleBox["n", "TI"], "-", "1"}], ")"}]], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], ",", "\\[NewLine]", 
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["y", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"], ",", 
             StyleBox["z", "TI"]}], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["n", "TI"], "\[LongEqual]", "1"}], 
          StyleBox["N", "TI"], LimitsPositioning -> True], 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", "-1", ")"}], 
           StyleBox["n", "TI"]], 
          RowBox[{
            SuperscriptBox["2", 
             RowBox[{"2", 
               StyleBox["n", "TI"], "-", "1"}]], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["n", "TI"], "-", "1"}], ")"}], "!", 
            StyleBox["n", "TI"], "!"}]], 
         StyleBox["y", "TI"], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["x", "TI"], "2"], "+", 
              SuperscriptBox[
               StyleBox["y", "TI"], "2"]}], ")"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], 
         SuperscriptBox[
          StyleBox["F", "TI"], 
          RowBox[{"(", 
            RowBox[{"2", 
              StyleBox["n", "TI"], "-", "1"}], ")"}]], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "."}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "F_z(x,y,z) &= \\sum_{n=0}^{N}\n\\frac{(-1)^n}{2^{2n}(n!)^2}\n\
(x^2+y^2)^n F^{(2n)}(z), \\\\\nF_x(x,y,z) &= \\sum_{n=1}^{N}\n\
\\frac{(-1)^n}{2^{2n-1}(n-1)!n!}\nx (x^2+y^2)^{n-1} F^{(2n-1)}(z), \\\\\n\
F_y(x,y,z) &= \\sum_{n=1}^{N}\n\\frac{(-1)^n}{2^{2n-1}(n-1)!n!}\ny \
(x^2+y^2)^{n-1} F^{(2n-1)}(z).", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "54100fb3-cff6-43e2-8272-1f12b8b0b466"],
 "\n\t\nHere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", 
     RowBox[{"(", "k", ")"}]], "(", "z", ")"}], TraditionalForm]],
  ExpressionUUID->"0ddfa284-5f08-4659-89b9-dbc0cc295c49"],
 " denotes the ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "37a2e360-f990-4f64-b652-cc5b4dc4c1f6"],
 "-th derivative with respect to ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "d336c8aa-4cfe-4e8c-80d4-59fe63f3b72c"],
 ", and the sum over ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["N", "TI"], TraditionalForm], "errors" -> {}, "input" -> "N", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8e9cb16f-6d24-4d4f-8d0f-51387e7e8cf2"],
 " captures:\n- ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "5dea789f-00be-4dda-9c01-839b5d34ca74"],
 ", the paraxial field\n- ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", " ", "\[GreaterEqual]", " ", "2"}], TraditionalForm]],
  ExpressionUUID->"355e57d7-57b7-45db-86d4-52916dc5438c"],
 ", spherical and higher-order aberrations"
}], "Text",
 CellChangeTimes->{{3.981544688990753*^9, 
  3.981545054200466*^9}},ExpressionUUID->"65a14e76-5235-4132-9ce1-\
0bea5061085c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"axialLaplaceExpansion", "[", 
   RowBox[{"field_", ",", 
    RowBox[{"{", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "}"}], ",", 
    RowBox[{"order_", ":", "2"}]}], "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r2", "=", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "n"], 
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}]], 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}], "!"}], 
           RowBox[{"n", "!"}]}]], "x", " ", 
         SuperscriptBox["r2", 
          RowBox[{"n", "-", "1"}]], 
         RowBox[{
          RowBox[{
           RowBox[{"Derivative", "[", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], "]"}], "[", "field", "]"}], "[", 
          "z", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "order"}], "}"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "n"], 
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}]], 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}], "!"}], 
           RowBox[{"n", "!"}]}]], "y", " ", 
         SuperscriptBox["r2", 
          RowBox[{"n", "-", "1"}]], 
         RowBox[{
          RowBox[{
           RowBox[{"Derivative", "[", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], "]"}], "[", "field", "]"}], "[", 
          "z", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "order"}], "}"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "n"], 
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{"2", "n"}]], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"n", "!"}], ")"}], "2"]}]], 
         SuperscriptBox["r2", "n"], 
         RowBox[{
          RowBox[{
           RowBox[{"Derivative", "[", 
            RowBox[{"2", "n"}], "]"}], "[", "field", "]"}], "[", "z", "]"}]}],
         ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "0", ",", "order"}], "}"}]}], "]"}]}], 
     "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",\

 InitializationCell->True,
 CellLabel->"In[8]:=",ExpressionUUID->"6cc0ba60-c948-4d54-950e-4b9b4640d55a"],

Cell["\<\
For example, the Glaser axial field we\[CloseCurlyQuote]ve investigated \
before admits to paraxial order:\
\>", "Text",
 CellChangeTimes->{{3.981545091911474*^9, 3.981545116911311*^9}, {
  3.981545244247024*^9, 
  3.9815452465030203`*^9}},ExpressionUUID->"f34c9cc2-f072-46d1-9259-\
69ad95bcd8c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"magneticField", "[", "\"\<glaser\>\"", "]"}], "[", 
     RowBox[{"a_", ",", "B0_"}], "]"}], "[", "z_", "]"}], "=", 
   RowBox[{"B0", "/", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["z", "a"], ")"}], "2"]}], ")"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9815451522414017`*^9, 3.981545152616428*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"a8ec8aaf-a59b-4a07-9d6f-2ac2e4452e08"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"axialLaplaceExpansion", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"magneticField", "[", "\"\<glaser\>\"", "]"}], "[", 
     RowBox[{"a", ",", "B0"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "z", "]"}], ",", 
      RowBox[{"y", "[", "z", "]"}], ",", "z"}], "}"}], ",", "1"}], "]"}], "//",
   "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.981545162644731*^9, 3.9815452019768963`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"a163407b-fbeb-4f5e-87aa-135d707a0b94"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["a", "2"], " ", "B0", " ", "z", " ", 
     RowBox[{"x", "[", "z", "]"}]}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["a", "2"], "+", 
       SuperscriptBox["z", "2"]}], ")"}], "2"]], ",", 
   FractionBox[
    RowBox[{
     SuperscriptBox["a", "2"], " ", "B0", " ", "z", " ", 
     RowBox[{"y", "[", "z", "]"}]}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["a", "2"], "+", 
       SuperscriptBox["z", "2"]}], ")"}], "2"]], ",", 
   FractionBox[
    RowBox[{
     SuperscriptBox["a", "2"], " ", "B0", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["a", "2"], "+", 
           SuperscriptBox["z", "2"]}], ")"}], "2"]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["a", "2"], "-", 
          RowBox[{"3", " ", 
           SuperscriptBox["z", "2"]}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"x", "[", "z", "]"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"y", "[", "z", "]"}], "2"]}], ")"}]}]}], ")"}]}], 
    RowBox[{"2", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        SuperscriptBox["z", "2"]}], ")"}], "3"]}]]}], "}"}]], "Output",
 CellChangeTimes->{{3.981545185169314*^9, 3.981545203123598*^9}, 
   3.981545253648498*^9, 3.98154749848491*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"a399d9a6-8b5c-4c4e-b449-3b680ada08b4"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Equations of Motion", "Section",
 CellChangeTimes->{{3.981545305359836*^9, 
  3.9815453092800922`*^9}},ExpressionUUID->"534bcbd7-c333-4f99-8763-\
7a8cb749879b"],

Cell[TextData[{
 "Given Cartesian electric and magnetic fields ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["E",
     FontWeight->"Bold"], "(", 
    RowBox[{"x", ",", "y", ",", "z"}], ")"}], TraditionalForm]],
  ExpressionUUID->"57f5ce61-3fa2-4319-978e-aff833dbdd75"],
 " and B(x,y,z), the ray equations in the paraxial longitudinal gauge are\n\t\
\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]\[Prime]"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "\[LongEqual]", "-", 
         FractionBox[
          SubscriptBox[
           StyleBox["E", "TI"], 
           StyleBox["x", "TI"]], "\[CapitalPhi]"], "+", 
         FractionBox["\[Eta]", 
          SqrtBox["\[CapitalPhi]"]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["B", "TI"], 
              StyleBox["y", "TI"]], "-", 
             SubscriptBox[
              StyleBox["B", "TI"], 
              StyleBox["z", "TI"]], 
             SuperscriptBox[
              StyleBox["y", "TI"], "\[Prime]"], 
             RowBox[{"(", 
               StyleBox["z", "TI"], ")"}]}], ")"}], ",", "\n", 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[Prime]\[Prime]"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "\[LongEqual]", "-", 
         FractionBox[
          SubscriptBox[
           StyleBox["E", "TI"], 
           StyleBox["y", "TI"]], "\[CapitalPhi]"], "-", 
         FractionBox["\[Eta]", 
          SqrtBox["\[CapitalPhi]"]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["B", "TI"], 
              StyleBox["x", "TI"]], "-", 
             SubscriptBox[
              StyleBox["B", "TI"], 
              StyleBox["z", "TI"]], 
             SuperscriptBox[
              StyleBox["x", "TI"], "\[Prime]"], 
             RowBox[{"(", 
               StyleBox["z", "TI"], ")"}]}], ")"}], ","}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "x''(z) &= -\\frac{E_x}{\\Phi}\n+ \\frac{\\eta}{\\sqrt{\\Phi}}\\left( \
B_y - B_z y'(z) \\right), \\\\\ny''(z) &= -\\frac{E_y}{\\Phi}\n- \
\\frac{\\eta}{\\sqrt{\\Phi}}\\left( B_x - B_z x'(z) \\right),", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2e177c31-42b2-4b81-96c7-c45d424991ca"],
 "\n\nwith ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Eta]", "\[LongEqual]", 
         SqrtBox[
          FractionBox[
           TemplateBox[{
             RowBox[{
               StyleBox["e", "TI"]}]}, "Abs"], 
           RowBox[{"2", 
             StyleBox["m", "TI"]}]]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\eta = \\sqrt{\\frac{|e|}{2m}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "baad3266-df40-4b5c-bd67-03af83f54d94"],
 "."
}], "Text",
 CellChangeTimes->{{3.981545314668051*^9, 
  3.981545333384177*^9}},ExpressionUUID->"2cc76770-f012-4f7e-8382-\
a0cc0cf42fca"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"equationsOfMotion", "[", 
    RowBox[{"\[Phi]0_", ",", "\[Eta]_", ",", "order_"}], "]"}], "[", 
   RowBox[{"\[Phi]field_", ",", "Bfield_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
     "x", ",", "y", ",", "z", ",", "\[IndentingNewLine]", "Ex", ",", "Ey", ",",
       "Ez", ",", "\[IndentingNewLine]", "Bx", ",", "By", ",", "Bz", ",", 
      "\[IndentingNewLine]", "\[Phi]"}], "\[IndentingNewLine]", "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Ex", ",", "Ey", ",", "Ez"}], "}"}], "=", 
      RowBox[{"-", 
       RowBox[{"axialLaplaceExpansion", "[", 
        RowBox[{
         RowBox[{"\[Phi]field", "'"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"x", "[", "z", "]"}], ",", 
           RowBox[{"y", "[", "z", "]"}], ",", "z"}], "}"}], ",", "order"}], 
        "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Bx", ",", "By", ",", "Bz"}], "}"}], "=", 
      RowBox[{"axialLaplaceExpansion", "[", 
       RowBox[{"Bfield", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "z", "]"}], ",", 
          RowBox[{"y", "[", "z", "]"}], ",", "z"}], "}"}], ",", "order"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Phi]", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"PossibleZeroQ", "[", 
         RowBox[{"\[Phi]field", "[", "z", "]"}], "]"}], ",", 
        RowBox[{"\[Phi]0", "&"}], ",", "\[Phi]field"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x", "''"}], "[", "z", "]"}], " ", "+", 
         RowBox[{
          FractionBox[
           RowBox[{
            RowBox[{"\[Phi]", "'"}], "[", "z", "]"}], 
           RowBox[{"2", " ", 
            RowBox[{"\[Phi]", "[", "z", "]"}]}]], 
          RowBox[{
           RowBox[{"x", "'"}], "[", "z", "]"}]}]}], "==", " ", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["Ex", 
           RowBox[{"2", 
            RowBox[{"\[Phi]", "[", "z", "]"}]}]]}], " ", "+", " ", 
         RowBox[{
          FractionBox["\[Eta]", 
           SqrtBox["\[Phi]0"]], 
          RowBox[{"(", 
           RowBox[{"By", "-", 
            RowBox[{"Bz", " ", 
             RowBox[{
              RowBox[{"y", "'"}], "[", "z", "]"}]}]}], ")"}]}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"y", "''"}], "[", "z", "]"}], " ", "+", 
         RowBox[{
          FractionBox[
           RowBox[{
            RowBox[{"\[Phi]", "'"}], "[", "z", "]"}], 
           RowBox[{"2", " ", 
            RowBox[{"\[Phi]", "[", "z", "]"}]}]], 
          RowBox[{
           RowBox[{"y", "'"}], "[", "z", "]"}]}]}], "==", " ", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["Ey", 
           RowBox[{"2", 
            RowBox[{"\[Phi]", "[", "z", "]"}]}]]}], " ", "-", " ", 
         RowBox[{
          FractionBox["\[Eta]", 
           SqrtBox["\[Phi]0"]], 
          RowBox[{"(", 
           RowBox[{"Bx", "-", 
            RowBox[{"Bz", " ", 
             RowBox[{
              RowBox[{"x", "'"}], "[", "z", "]"}]}]}], ")"}]}]}]}]}], 
      "\[IndentingNewLine]", "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9815453419940147`*^9, 3.981545351346611*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"7d215a57-0107-491a-864b-c2923d7276fe"],

Cell["This formulation:", "Text",
 CellChangeTimes->{{3.9785782270274897`*^9, 
  3.978578232495925*^9}},ExpressionUUID->"7b05b287-6daa-4322-9117-\
e0c78a2ea15b"],

Cell["is valid beyond the paraxial approximation,", "Item",
 CellChangeTimes->{{3.978578142735365*^9, 
  3.978578147643694*^9}},ExpressionUUID->"7e2ba85a-fdf9-4784-b45f-\
21aec8a37bc0"],

Cell["naturally includes coupling between position and slope,", "Item",
 CellChangeTimes->{{3.978578142735365*^9, 
  3.978578150307704*^9}},ExpressionUUID->"2c802758-6065-4d9b-9bb8-\
f270cc744e10"],

Cell["\<\
reduces to standard paraxial ODEs when fields are linearized.\
\>", "Item",
 CellChangeTimes->{{3.978578142735365*^9, 
  3.978578149810431*^9}},ExpressionUUID->"e80d4501-2ffb-4d53-bd3a-\
daa2f4c60911"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Electrostatic Fields", "Section",
 CellChangeTimes->{{3.981548548538505*^9, 3.981548554201632*^9}, {
  3.98154892669178*^9, 3.98154892771377*^9}, {3.981549781026619*^9, 
  3.981549783594705*^9}},ExpressionUUID->"22e8daaf-224d-402e-8957-\
2eed8a6f98ad"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s see how order=1 reduces to the paraxial equations \
for an electrostatic-only field.\nNote: We use a zero-evaluating \
pure-function: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"0", " ", "&"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5a6d9eb8-a185-4678-b5f1-fac311518db3"],
 ") to trick the function into accepting a purely-electrostatic field."
}], "Text",
 CellChangeTimes->{{3.981545629132077*^9, 
  3.981545746344491*^9}},ExpressionUUID->"ce18e63b-2e34-4b5d-9791-\
21679761be4f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"equationsOfMotion", "[", 
    RowBox[{"\[Phi]0", ",", "\[Eta]", ",", "1"}], "]"}], "[", 
   RowBox[{"\[Phi]", ",", 
    RowBox[{"0", "&"}]}], "]"}], "//", "Expand"}]], "Input",
 CellChangeTimes->{{3.981545500713408*^9, 3.9815455361712627`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"130d725a-62d9-44f9-93e3-eba28d5685c8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{
        SuperscriptBox["x", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[Phi]", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"2", " ", 
       RowBox[{"\[Phi]", "[", "z", "]"}]}]], "+", 
     RowBox[{
      SuperscriptBox["x", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "z", "]"}]}], "\[Equal]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       RowBox[{"x", "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"4", " ", 
       RowBox[{"\[Phi]", "[", "z", "]"}]}]]}]}], ",", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{
        SuperscriptBox["y", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[Phi]", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"2", " ", 
       RowBox[{"\[Phi]", "[", "z", "]"}]}]], "+", 
     RowBox[{
      SuperscriptBox["y", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "z", "]"}]}], "\[Equal]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       RowBox[{"y", "[", "z", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"4", " ", 
       RowBox[{"\[Phi]", "[", "z", "]"}]}]]}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9815455058584948`*^9, 3.981545536378379*^9, 
  3.981545708731887*^9, 3.981545748696114*^9, 3.981547502600156*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"12f6d2a3-cd4d-47cd-978e-5315081753c1"]
}, Open  ]],

Cell[TextData[{
 "Indeed, if we take one of these equations we see it\[CloseCurlyQuote]s \
identical to our paraxial equation:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       StyleBox["r", "TI"], "\[Prime]\[Prime]"], "(", 
      StyleBox["z", "TI"], ")"}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Prime]"], "(", 
        StyleBox["z", "TI"], ")"}], 
       RowBox[{"2", 
        RowBox[{"\[CapitalPhi]", "(", 
         StyleBox["z", "TI"], ")"}]}]], 
      RowBox[{
       SuperscriptBox[
        StyleBox["r", "TI"], "\[Prime]"], "(", 
       StyleBox["z", "TI"], ")"}]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Prime]\[Prime]"], "(", 
        StyleBox["z", "TI"], ")"}], 
       RowBox[{"4", 
        RowBox[{"\[CapitalPhi]", "(", 
         StyleBox["z", "TI"], ")"}]}]], 
      RowBox[{
       StyleBox["r", "TI"], "(", 
       StyleBox["z", "TI"], ")"}]}]}], "\[LongEqual]", "0."}], 
   TraditionalForm]],ExpressionUUID->"63a18e0f-b80e-4cb3-880d-a91798359afd"]
}], "Text",
 CellChangeTimes->{{3.981545750656302*^9, 
  3.9815457950614653`*^9}},ExpressionUUID->"0732c371-1549-479b-b812-\
a15e9c01581d"],

Cell["\<\
Increasing the order argument, naturally introduces higher-order terms which \
determine aberrations.\
\>", "Text",
 CellChangeTimes->{{3.9815458176728973`*^9, 
  3.981545840760859*^9}},ExpressionUUID->"ae935bcb-758e-49ec-860a-\
876301163ec9"],

