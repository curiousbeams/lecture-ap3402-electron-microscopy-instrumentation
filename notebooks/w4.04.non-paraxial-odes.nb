Cell[BoxData[
 RowBox[{
  RowBox[{"nonParaxialRayTracing", "[", 
   RowBox[{"eqns_", ",", 
    RowBox[{"{", 
     RowBox[{"z0_", ",", "zf_"}], "}"}], ",", "opts___"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "x", ",", "y", ",", "z", ",", "x0", ",", "y0", ",", "xp0", ",", "yp0"}], 
     "}"}], ",", 
    RowBox[{"ParametricNDSolveValue", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Join", "[", "\[IndentingNewLine]", 
       RowBox[{"eqns", ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "[", "z0", "]"}], "==", "x0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], "[", "z0", "]"}], "==", "xp0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"y", "[", "z0", "]"}], "==", "y0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "'"}], "[", "z0", "]"}], "==", "yp0"}]}], 
         "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "z0", ",", "zf"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"x0", ",", "y0", ",", "xp0", ",", "yp0"}], "}"}], ",", 
      "\[IndentingNewLine]", "opts"}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->"In[4]:=",ExpressionUUID->"7e385d27-672a-4c7f-8b96-29f9c0b9841e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"physicalConstants", "=", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<e\>\"", "->", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<ElementaryCharge\>\"", "]"}], 
        ",", "\"\<SIBase\>\""}], "]"}]}], ",", 
     RowBox[{"\"\<m\>\"", "->", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<ElectronMass\>\"", "]"}], 
        ",", "\"\<SIBase\>\""}], "]"}]}], ",", 
     RowBox[{"\"\<c\>\"", "->", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<SpeedOfLight\>\"", "]"}], 
        ",", "\"\<SIBase\>\""}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<\[Eta]\>\"", ":>", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"physicalConstants", "[", "\"\<e\>\"", "]"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", 
          RowBox[{"physicalConstants", "[", "\"\<m\>\"", "]"}]}], ")"}]}], 
       "]"}]}]}], "\[IndentingNewLine]", "|>"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellLabel->"In[5]:=",ExpressionUUID->"e733cf87-b35e-44dc-ba49-5fbd064f56e1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"electrostaticField", "[", "\"\<schiske\>\"", "]"}], "[", 
      RowBox[{"a_", ",", "k_", ",", "\[Phi]0_"}], "]"}], "[", "z_", "]"}], "=", 
    RowBox[{"\[Phi]0", " ", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"k", "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"z", "/", "a"}], ")"}], "^", "2"}]}], ")"}]}]}], 
      ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"buildRayTracer", "[", 
   RowBox[{"\"\<schiske\>\"", ",", "order_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Phi]0", "=", "5"}], ",", "\[IndentingNewLine]", 
      RowBox[{"a", "=", "0.025"}], ",", "\[IndentingNewLine]", 
      RowBox[{"k", "=", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"z0", "=", 
       RowBox[{"-", "0.5"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"zf", "=", "1"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\[Eta]", "=", 
       RowBox[{"physicalConstants", "[", "\"\<\[Eta]\>\"", "]"}]}], ",", 
      "\[IndentingNewLine]", "\[Phi]field", ",", "\[IndentingNewLine]", 
      "eom"}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Phi]field", "=", 
      RowBox[{
       RowBox[{"electrostaticField", "[", "\"\<schiske\>\"", "]"}], "[", 
       RowBox[{"a", ",", "k", ",", "\[Phi]0"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"eom", "=", 
      RowBox[{
       RowBox[{"equationsOfMotion", "[", 
        RowBox[{"\[Phi]0", ",", "\[Eta]", ",", "order"}], "]"}], "[", 
       RowBox[{"\[Phi]field", ",", 
        RowBox[{"0", "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nonParaxialRayTracing", "[", 
      RowBox[{"eom", ",", 
       RowBox[{"{", 
        RowBox[{"z0", ",", "zf"}], "}"}], ",", 
       RowBox[{"MaxSteps", "->", "100000"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9815485766116247`*^9, 3.981548588449127*^9}, {
  3.981548650076387*^9, 3.981548650275815*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"d505ac25-565e-4b12-ba08-d1851b334440"],

Cell[BoxData[
 RowBox[{
  RowBox[{"coneOfRays", "[", 
   RowBox[{"numAngularRays_", ",", 
    RowBox[{"numRadialRays_", ":", "3"}], ",", 
    RowBox[{"x0_", ":", "0"}], ",", " ", 
    RowBox[{"y0_", ":", "0"}], ",", " ", 
    RowBox[{"minimumRadial_", ":", 
     RowBox[{"1", " ", 
      SuperscriptBox["10", 
       RowBox[{"-", "3"}]]}]}], ",", " ", 
    RowBox[{"maximumRadial_", ":", 
     RowBox[{"1", " ", 
      SuperscriptBox["10", 
       RowBox[{"-", "2"}]]}]}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Theta]list", ",", "\[Phi]list", ",", "initialConditions"}], 
     "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Theta]list", "=", 
      RowBox[{
       RowBox[{"Subdivide", "[", 
        RowBox[{"minimumRadial", ",", "maximumRadial", ",", "numRadialRays"}],
         "]"}], "//", "Most"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Phi]list", "=", 
      RowBox[{
       RowBox[{"Subdivide", "[", 
        RowBox[{"0", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", "numAngularRays"}], "]"}], "//", 
       "Most"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x0", ",", "y0", ",", 
           RowBox[{"\[Theta]", " ", 
            RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
           RowBox[{"\[Theta]", " ", 
            RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", "\[Theta]list"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "\[Phi]list"}], "}"}]}], "]"}], ",", "1"}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.981548617746928*^9, 3.9815486274576273`*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"63ed83f9-e6a0-40f3-ab06-0f725945aaec"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rayTracer", "[", "\"\<schiske\>\"", "]"}], "=", 
   RowBox[{"buildRayTracer", "[", 
    RowBox[{"\"\<schiske\>\"", ",", "3"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nonParaxialRays", "[", "\"\<schiske\>\"", "]"}], "=", 
    RowBox[{"ParallelMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"rayTracer", "[", "\"\<schiske\>\"", "]"}], "@@", "#"}], 
       "&"}], ",", 
      RowBox[{"coneOfRays", "[", "24", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"schiskeRays", "=", 
  RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Evaluate", "@", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Prepend", "[", 
         RowBox[{
          RowBox[{"Through", "[", 
           RowBox[{"#", "[", "z", "]"}], "]"}], ",", "z"}], "]"}], "&"}], ",", 
       RowBox[{"nonParaxialRays", "[", "\"\<schiske\>\"", "]"}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", 
      RowBox[{"-", "0.5"}], ",", "1.0"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"BoxRatios", "->", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1"}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"RGBColor", "[", 
      RowBox[{"0", ",", "0.5", ",", "0"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9815486321507177`*^9, 3.981548633826626*^9}, {
