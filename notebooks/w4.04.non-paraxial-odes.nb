        SuperscriptBox["\[Phi]", "\[Prime]",
         MultilineFunction->None], "[", "z", "]"}]}], 
      RowBox[{"2", " ", 
       RowBox[{"\[Phi]", "[", "z", "]"}]}]], "+", 
     RowBox[{
