Notebook[{

Cell[CellGroupData[{
Cell["Physics of Electron Microscopy Instrumentation", "Title",
 CellChangeTimes->{{3.9814466515808773`*^9, 
  3.9814466605467*^9}},ExpressionUUID->"dc91f36d-26b5-488b-a2c6-2e2037e1d326"],

Cell["Georgios Varnavides | March 2nd 2026", "Subtitle",
 CellChangeTimes->{{3.9814466652477837`*^9, 
  3.9814466774444857`*^9}},ExpressionUUID->"597510af-f54b-4bcf-a005-\
fb06497f3bbc"],

Cell[CellGroupData[{

Cell["Paraxial Ray Equation", "Chapter",
 CellChangeTimes->{{3.981446681326468*^9, 3.9814466939325247`*^9}, {
  3.9815366436048727`*^9, 
  3.981536647029811*^9}},ExpressionUUID->"8344c7f8-902a-4f80-81eb-\
22075d5d24f8"],

Cell[CellGroupData[{

Cell["Introduction", "Section",
 CellChangeTimes->{{3.978510590274658*^9, 3.978510591282824*^9}, {
  3.978511097092923*^9, 
  3.978511102651667*^9}},ExpressionUUID->"97034976-de50-4dbe-a7a5-\
dc829973bc9c"],

Cell[TextData[{
 "In electron optics, the trajectory of an electron moving predominantly \
along the optic axis $z$ can be described using the paraxial approximation, \
in which transverse displacements ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r(z)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "942a51e7-9cd5-4660-a850-0d7c03584c98"],
 " are small and ray angles satisfy ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SuperscriptBox[
          StyleBox["r", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "|", "\[LessLess]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "|r'(z)| \\ll 1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "33b64bf0-f0a8-42b4-81b5-76ecc46f8957"],
 ". Under this assumption we retain only terms up to first order in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2aa94ff7-ab49-42ee-a90f-652548ffbb9d"],
 " (equivalently up to quadratic order in the potential expansion), and \
neglect higher-order transverse terms that give rise to aberrations."
}], "Text",
 CellChangeTimes->{{3.981536959331547*^9, 
  3.981536998548216*^9}},ExpressionUUID->"df174fd0-54ec-4c26-b320-\
4cab8393f098"],

Cell[CellGroupData[{

Cell["Electrostatic Focusing", "Subsection",
 CellChangeTimes->{{3.981537023525447*^9, 
  3.9815370288694267`*^9}},ExpressionUUID->"c55121ee-f9ca-4e8f-9702-\
fd9e864d94c8"],

Cell[TextData[{
 "We have already seen that in a cylindrically symmetric, charge-free region, \
the electrostatic potential satisfies Laplace\[CloseCurlyQuote]s equation. \
Near the axis, we can retain the quadratic term only:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPhi]", "(", 
     RowBox[{
      StyleBox["r", "TI"], ",", 
      StyleBox["z", "TI"]}], ")"}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"\[CapitalPhi]", "(", 
      StyleBox["z", "TI"], ")"}], "-", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        StyleBox["r", "TI"], "2"], "4"], 
      RowBox[{
       SuperscriptBox["\[CapitalPhi]", "\[Prime]\[Prime]"], "(", 
       StyleBox["z", "TI"], ")"}]}], "+", 
     RowBox[{
      RowBox[{
       StyleBox["O", "TI"], "(", 
       SuperscriptBox[
        StyleBox["r", "TI"], "4"], ")"}], "."}]}]}], TraditionalForm]],
  ExpressionUUID->"12ca9015-ef53-4257-a4c7-db9a7910f747"],
 "\n\t\nThe transverse electric field then follows from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["E",
      FontSlant->"Bold"], "\[LongEqual]", 
     RowBox[{"-", 
      RowBox[{"\[Del]", "\[CapitalPhi]"}]}]}], ","}], TraditionalForm]],
  ExpressionUUID->"84b15253-56f0-477a-b4cc-6923a033ed25"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["E", "TI"], 
     StyleBox["r", "TI"]], "\[LongEqual]", 
    RowBox[{
     FractionBox[
      StyleBox["r", "TI"], "2"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[CapitalPhi]", "\[Prime]\[Prime]"], "(", 
       StyleBox["z", "TI"], ")"}], "."}]}]}], TraditionalForm]],
  ExpressionUUID->"44ceac87-fabd-4717-a50c-73d81d3d2d55"]
}], "Text",
 CellChangeTimes->{{3.9815370548158617`*^9, 3.981537117259163*^9}, {
   3.9815371501803427`*^9, 3.981537178521702*^9}, 3.981537231165855*^9, {
   3.981537335286585*^9, 
   3.981537336357687*^9}},ExpressionUUID->"dc56b56c-bcd3-4e13-b252-\
bb3dae271f25"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"paraxialPotential", "[", 
    RowBox[{"r_", ",", "z_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"\[Phi]", "[", "z", "]"}], "-", 
    RowBox[{
     FractionBox[
      SuperscriptBox["r", "2"], "4"], 
     RowBox[{
      RowBox[{"\[Phi]", "''"}], "[", "z", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"paraxialRadialField", "[", 
   RowBox[{"r_", ",", "z_"}], "]"}], "=", 
  RowBox[{"-", 
   RowBox[{
    RowBox[{
     RowBox[{"Derivative", "[", 
      RowBox[{"1", ",", "0"}], "]"}], "[", "paraxialPotential", "]"}], "[", 
    RowBox[{"r", ",", "z"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{3.9815374674307613`*^9},
 CellLabel->
  "In[730]:=",ExpressionUUID->"3b2cb81e-5fcb-47d5-bfbb-cddf32087c54"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "r", " ", 
  RowBox[{
   SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
    MultilineFunction->None], "[", "z", "]"}]}]], "Output",
 CellChangeTimes->{3.981537468224586*^9},
 CellLabel->
  "Out[731]=",ExpressionUUID->"882f10d1-d110-4d87-86f0-1cd398a5cfb8"]
}, Open  ]],

Cell[TextData[{
 "The Lorentz force for a purely electrostatic system is\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["m", "TI"], 
     FractionBox[
      RowBox[{
       SuperscriptBox[
        StyleBox["d", "TI"], "2"], 
       StyleBox["r",
        FontSlant->"Bold"]}], 
      RowBox[{
       StyleBox["d", "TI"], 
       SuperscriptBox[
        StyleBox["t", "TI"], "2"]}]]}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"-", 
      StyleBox["e", "TI"]}], 
     RowBox[{
      StyleBox["E",
       FontSlant->"Bold"], "."}]}]}], TraditionalForm]],ExpressionUUID->
  "2a544f10-456c-4db2-a1e9-90bd94aae47b"],
 "\n\t\nUsing ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["z", "TI"], TraditionalForm], "errors" -> {}, "input" -> "z", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fc626bf4-c099-4663-a4ad-4ac1dce7ea55"],
 " as the independent variable and noting that the axial velocity satisfies \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["z", "TI"], "2"], "\[LongEqual]", 
     RowBox[{
      FractionBox[
       RowBox[{"2", 
        StyleBox["e", "TI"]}], 
       StyleBox["m", "TI"]], 
      RowBox[{"\[CapitalPhi]", "(", 
       StyleBox["z", "TI"], ")"}]}]}], ","}], TraditionalForm]],
  ExpressionUUID->"c76ea79f-1c80-472e-8b20-78e0c97140a8"],
 " we transform derivatives via\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["v", "TI"], 
          StyleBox["z", "TI"]], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], 
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["z", "TI"]}]], "."}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{d}{dt} = v_z(z) \\frac{d}{dz}.", "state" -> "Boxes"|>,
    
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "73d3282d-7a33-400d-a3c5-f1e35f390215"],
 "\n\nKeeping only paraxial terms (linear in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fdb54701-24f6-488a-8224-db48474cadfb"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["r", "TI"], "\[Prime]"], TraditionalForm], "errors" -> {}, 
     "input" -> "r'", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "89baa68d-467c-42e5-b249-d5e6c9cc1e0d"],
 "), the transverse equation becomes\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       StyleBox["r", "TI"], "\[Prime]\[Prime]"], "(", 
      StyleBox["z", "TI"], ")"}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Prime]"], "(", 
        StyleBox["z", "TI"], ")"}], 
       RowBox[{"2", 
        RowBox[{"\[CapitalPhi]", "(", 
         StyleBox["z", "TI"], ")"}]}]], 
      RowBox[{
       SuperscriptBox[
        StyleBox["r", "TI"], "\[Prime]"], "(", 
       StyleBox["z", "TI"], ")"}]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Prime]\[Prime]"], "(", 
        StyleBox["z", "TI"], ")"}], 
       RowBox[{"4", 
        RowBox[{"\[CapitalPhi]", "(", 
         StyleBox["z", "TI"], ")"}]}]], 
      RowBox[{
       StyleBox["r", "TI"], "(", 
       StyleBox["z", "TI"], ")"}]}]}], "\[LongEqual]", "0."}], 
   TraditionalForm]],ExpressionUUID->"10d08ff5-88cf-499a-96d2-30d3e684bcc8"]
}], "Text",
 CellChangeTimes->{{3.981537216055047*^9, 
  3.981537347695334*^9}},ExpressionUUID->"da9551ae-a09a-4ea1-bec0-\
a02622b4805b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"squaredVelocity", "[", "z_", "]"}], ":=", 
   RowBox[{"2", " ", 
    RowBox[{
     RowBox[{"\[Phi]", "[", "z", "]"}], "/", "m"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chainRuleDoubleTimeDerivative", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"squaredVelocity", "[", "z", "]"}], " ", 
     RowBox[{
      RowBox[{"r", "''"}], "[", "z", "]"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"squaredVelocity", "[", "z", "]"}], ",", "z"}], "]"}], "/", 
      "2"}], " ", 
     RowBox[{
      RowBox[{"r", "'"}], "[", "z", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"m", " ", "chainRuleDoubleTimeDerivative"}], " ", "+", " ", 
   RowBox[{"paraxialRadialField", "[", 
    RowBox[{"r", ",", "z"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Expand", "[", 
  RowBox[{"%", "/", " ", 
   RowBox[{"(", 
    RowBox[{"2", " ", 
     RowBox[{"\[Phi]", "[", "z", "]"}]}], ")"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.981538030772894*^9, 3.981538117605444*^9}, {
  3.9815381904305687`*^9, 3.981538197230029*^9}, {3.9815382712086353`*^9, 
  3.981538271800252*^9}, {3.981538323592952*^9, 3.981538350768126*^9}, {
  3.9815390114562197`*^9, 3.981539033363001*^9}},
 CellLabel->
  "In[797]:=",ExpressionUUID->"f674cffe-3a41-425f-bdc8-9970d21b2356"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["r", "\[Prime]",
     MultilineFunction->None], "[", "z", "]"}], " ", 
   RowBox[{
    SuperscriptBox["\[Phi]", "\[Prime]",
     MultilineFunction->None], "[", "z", "]"}]}], "+", 
  RowBox[{"2", " ", 
   RowBox[{"\[Phi]", "[", "z", "]"}], " ", 
   RowBox[{
    SuperscriptBox["r", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "z", "]"}]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "r", " ", 
   RowBox[{
    SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "z", "]"}]}]}]], "Output",
 CellChangeTimes->{
  3.981538088519293*^9, 3.981538144174302*^9, {3.98153819257066*^9, 
   3.981538197884429*^9}, 3.9815382731003304`*^9, {3.9815383250803957`*^9, 
   3.981538352119282*^9}, {3.981539018126955*^9, 3.981539033689796*^9}},
 CellLabel->
  "Out[799]=",ExpressionUUID->"119382d4-6ef1-4655-bf91-0b9e5294144b"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["r", "\[Prime]",
      MultilineFunction->None], "[", "z", "]"}], " ", 
    RowBox[{
     SuperscriptBox["\[Phi]", "\[Prime]",
      MultilineFunction->None], "[", "z", "]"}]}], 
   RowBox[{"2", " ", 
    RowBox[{"\[Phi]", "[", "z", "]"}]}]], "+", 
  RowBox[{
   SuperscriptBox["r", "\[Prime]\[Prime]",
    MultilineFunction->None], "[", "z", "]"}], "+", 
  FractionBox[
   RowBox[{"r", " ", 
    RowBox[{
     SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "z", "]"}]}], 
   RowBox[{"4", " ", 
    RowBox[{"\[Phi]", "[", "z", "]"}]}]]}]], "Output",
 CellChangeTimes->{
  3.981538088519293*^9, 3.981538144174302*^9, {3.98153819257066*^9, 
   3.981538197884429*^9}, 3.9815382731003304`*^9, {3.9815383250803957`*^9, 
   3.981538352119282*^9}, {3.981539018126955*^9, 3.981539033690694*^9}},
 CellLabel->
  "Out[800]=",ExpressionUUID->"ed71a65f-4bc9-4225-b5db-21b3808e0b30"]
}, Open  ]],

Cell[TextData[{
 "The coefficient ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[CapitalPhi]", "\[Prime]\[Prime]"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "/", 
         RowBox[{"(", 
           RowBox[{"4", "\[CapitalPhi]", 
             RowBox[{"(", 
               StyleBox["z", "TI"], ")"}]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\Phi''(z)/(4\\Phi(z))", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "be7e0dd6-dfc4-4156-b9ef-11d1e5d8ceb6"],
 " arises directly from the axial curvature of the harmonic potential, while \
the term ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[CapitalPhi]", "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "/", 
         RowBox[{"(", 
           RowBox[{"2", "\[CapitalPhi]", 
             RowBox[{"(", 
               StyleBox["z", "TI"], ")"}]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\Phi'(z)/(2\\Phi(z))", "state" -> "Boxes"|>,
    
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4a43d126-69bd-4c99-bca1-d8a6cb9fc683"],
 " reflects longitudinal acceleration as the electron gains kinetic energy."
}], "Text",
 CellChangeTimes->{{3.9815383597995157`*^9, 3.981538401903481*^9}, {
  3.9815389728805847`*^9, 3.98153899952465*^9}, {3.98153905768054*^9, 
  3.981539160094905*^9}},ExpressionUUID->"c775e306-7808-4f16-b1de-\
37376e47ef7c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"linearizedODE", "[", "\[Phi]0_", "]"}], "[", "\[Phi]_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"r", "''"}], "[", "z", "]"}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "z", "]"}], 
        RowBox[{"2", " ", 
         RowBox[{"\[Phi]", "[", "z", "]"}]}]], " ", 
       RowBox[{
        RowBox[{"r", "'"}], "[", "z", "]"}]}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"\[Phi]", "''"}], "[", "z", "]"}], 
        RowBox[{"4", " ", 
         RowBox[{"\[Phi]", "[", "z", "]"}]}]], 
       RowBox[{"r", "[", "z", "]"}]}]}], "==", "0"}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[801]:=",ExpressionUUID->"0e8af2c7-229c-48ca-8ee5-9b7460d62c22"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Magnetic Focusing", "Subsection",
 CellChangeTimes->{{3.981539170311777*^9, 
  3.98153917206314*^9}},ExpressionUUID->"459cda9b-432a-40f0-9f75-\
d577ce82e7aa"],

Cell[TextData[{
 "For a purely magnetic, axially symmetric lens, the near-axis magnetic field \
satisfies\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["B", "TI"], 
     StyleBox["r", "TI"]], "\[LongEqual]", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       StyleBox["r", "TI"], "2"]}], 
     RowBox[{
      FractionBox[
       RowBox[{
        StyleBox["d", "TI"], 
        SubscriptBox[
         StyleBox["B", "TI"], 
         StyleBox["z", "TI"]]}], 
       StyleBox[
        RowBox[{"d", "z"}], "TI"]], "."}]}]}], TraditionalForm]],
  ExpressionUUID->"abe7667d-aab7-4007-bd64-e7194be037af"],
 "\n\t\nThe Lorentz force is now given by:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["m", "TI"], 
     FractionBox[
      RowBox[{
       StyleBox["d", "TI"], 
       StyleBox["v",
        FontSlant->"Bold"]}], 
      StyleBox[
       RowBox[{"d", "t"}], "TI"]]}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"-", 
      StyleBox["e", "TI"]}], " ", 
     StyleBox["v",
      FontSlant->"Bold"], "\[Times]", 
     RowBox[{
      StyleBox["B",
       FontSlant->"Bold"], "."}]}]}], TraditionalForm]],ExpressionUUID->
  "59a8e6fd-1961-4814-8fdc-a2613bf28876"],
 "\n\t\nIn the paraxial limit, the dominant effect is Larmor rotation about \
the axis. Eliminating the azimuthal motion yields an effective radial \
restoring force proportional to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["B", "TI"], 
        StyleBox["z", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "B_z^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0b1641bc-77bf-4bac-b4e9-536d18177df4"],
 ".\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox[
        StyleBox["r", "TI"], "\[Prime]\[Prime]"], "(", 
       StyleBox["z", "TI"], ")"}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox["\[Eta]", "2"], 
         RowBox[{
          SuperscriptBox[
           StyleBox["B", "TI"], "2"], "(", 
          StyleBox["z", "TI"], ")"}]}], 
        RowBox[{"4", 
         SubscriptBox["\[CapitalPhi]", "0"]}]], " ", 
       RowBox[{
        StyleBox["r", "TI"], "(", 
        StyleBox["z", "TI"], ")"}]}]}], "\[LongEqual]", "0"}], ","}], 
   TraditionalForm]],ExpressionUUID->"f73f0900-46b7-49df-bd06-f36e5a7badf1"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Eta]", "\[LongEqual]", 
    SqrtBox[
     FractionBox[
      TemplateBox[{
        RowBox[{
          StyleBox["e", "TI"]}]},
       "Abs"], 
      RowBox[{"2", 
       StyleBox["m", "TI"]}]]]}], TraditionalForm]],ExpressionUUID->
  "3d46f053-3035-4b09-bf92-ed902d41ccd7"],
 "and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[CapitalPhi]", "0"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Phi_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1a4ab38b-7a6d-416a-ba32-b98660ed5e8b"],
 " is the accelerating potential (constant energy).\n\nMagnetic lenses focus \
not through axial curvature, but through rotational dynamics: the conserved \
canonical angular momentum produces a quadratic restoring force proportional \
to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["B", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "B^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d7d6a1ab-4db2-477f-9704-de16033b5914"],
 "."
}], "Text",
 CellChangeTimes->{{3.981539192195209*^9, 
  3.981539392898226*^9}},ExpressionUUID->"08808b6a-25b2-48cc-ae7c-\
60f79b9000b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"linearizedODE", "[", 
    RowBox[{"\[Phi]0_", ",", "\[Eta]_"}], "]"}], "[", "B_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"r", "''"}], "[", "z", "]"}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox["\[Eta]", "2"], " ", 
         SuperscriptBox[
          RowBox[{"B", "[", "z", "]"}], "2"]}], 
        RowBox[{"4", " ", "\[Phi]0"}]], 
       RowBox[{"r", "[", "z", "]"}]}]}], "==", "0"}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[802]:=",ExpressionUUID->"52db391a-d33f-4ace-8bae-c590ec0e5bd8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Paraxial Ray Equation", "Subsection",
 CellChangeTimes->{{3.981539417872953*^9, 
  3.98153942526377*^9}},ExpressionUUID->"320c5b02-063e-465e-80ba-\
e3f57424bec5"],

Cell[TextData[{
 "For an axially symmetric system with on-axis electrostatic potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "(", "z", ")"}], TraditionalForm]],ExpressionUUID->
  "210bb2f5-6ae5-4fc0-ae7f-2d035c9f88c0"],
 " and axial magnetic field ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "(", "z", ")"}], TraditionalForm]],ExpressionUUID->
  "0e22f3cb-c86c-468e-b836-af77100f9608"],
 ", the paraxial ray equation takes the form:\n\t",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SuperscriptBox[
         StyleBox["r", "TI"], "\[Prime]\[Prime]"], 
        RowBox[{"(", 
          StyleBox["z", "TI"], ")"}], "+", 
        FractionBox[
         RowBox[{
           SuperscriptBox["\[Phi]", "\[Prime]"], "(", 
           StyleBox["z", "TI"], ")"}], 
         RowBox[{"2", "\[Phi]", 
           RowBox[{"(", 
             StyleBox["z", "TI"], ")"}]}]], 
        SuperscriptBox[
         StyleBox["r", "TI"], "\[Prime]"], 
        RowBox[{"(", 
          StyleBox["z", "TI"], ")"}], "+", 
        RowBox[{"[", 
          RowBox[{
            FractionBox[
             RowBox[{
               SuperscriptBox["\[Phi]", "\[Prime]\[Prime]"], "(", 
               StyleBox["z", "TI"], ")"}], 
             RowBox[{"4", "\[Phi]", 
               RowBox[{"(", 
                 StyleBox["z", "TI"], ")"}]}]], "+", 
            FractionBox[
             RowBox[{
               SuperscriptBox["\[Eta]", "2"], 
               SuperscriptBox[
                StyleBox["B", "TI"], "2"], 
               RowBox[{"(", 
                 StyleBox["z", "TI"], ")"}]}], 
             RowBox[{"4", 
               SubscriptBox["\[Phi]", "0"]}]]}], "]"}], 
        StyleBox["r", "TI"], 
        RowBox[{"(", 
          StyleBox["z", "TI"], ")"}], "\[LongEqual]", "0"}], TraditionalForm],
     "errors" -> {}, "input" -> 
    "r''(z) + \\frac{\\phi'(z)}{2 \\phi(z)}r'(z) + \
\\left[\\frac{\\phi''(z)}{4 \\phi(z)} + \\frac{\\eta^2 B^2(z)}{4 \\phi_0} \
\\right] r(z) =0", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "004377b5-0274-4db6-a5a3-2d15069591db"],
 ",\n\t\nThis second-order ODE forms the foundation of paraxial electron \
optics.Its solutions describe principal and marginal rays,while its \
coefficients encode the focusing properties of electrostatic curvature and \
magnetic rotation."
}], "Text",
 CellChangeTimes->{{3.9815394304588327`*^9, 
  3.981539470000966*^9}},ExpressionUUID->"5ec66e57-61e5-4c3c-b5c3-\
3454d2893fb0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"linearizedODE", "[", 
    RowBox[{"\[Phi]0_", ",", "\[Eta]_"}], "]"}], "[", 
   RowBox[{"\[Phi]_", ",", "B_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"r", "''"}], "[", "z", "]"}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "z", "]"}], 
        RowBox[{"2", " ", 
         RowBox[{"\[Phi]", "[", "z", "]"}]}]], " ", 
       RowBox[{
        RowBox[{"r", "'"}], "[", "z", "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         FractionBox[
          RowBox[{
           RowBox[{"\[Phi]", "''"}], "[", "z", "]"}], 
          RowBox[{"4", " ", 
           RowBox[{"\[Phi]", "[", "z", "]"}]}]], "+", 
         FractionBox[
          RowBox[{
           SuperscriptBox["\[Eta]", "2"], " ", 
           SuperscriptBox[
            RowBox[{"B", "[", "z", "]"}], "2"]}], 
          RowBox[{"4", " ", "\[Phi]0"}]]}], ")"}], 
       RowBox[{"r", "[", "z", "]"}]}]}], "==", "0"}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[803]:=",ExpressionUUID->"107d95ad-9aac-43b0-b669-7e979f0bdc5a"],

Cell[TextData[{
 StyleBox["Coding aside:",
  FontWeight->"Bold"],
 "\nNotice we used pattern-matching (Mathematica\[CloseCurlyQuote]s \
equivalent of multiple dispatch), to define the same function with three \
different call signatures to cover the special cases where there\
\[CloseCurlyQuote]s only electrostatic or magnetic fields"
}], "CodeText",
 CellChangeTimes->{{3.978510900763685*^9, 3.9785109353637037`*^9}, {
  3.978511029996626*^9, 3.978511089715088*^9}, {3.978512429212626*^9, 
  3.97851242955651*^9}},ExpressionUUID->"083e60e5-6c92-4bce-8db2-\
a4ffec3bf5ab"],

Cell[BoxData[
 RowBox[{
  RowBox[{"physicalConstants", "=", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<e\>\"", "->", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<ElementaryCharge\>\"", "]"}], 
        ",", "\"\<SIBase\>\""}], "]"}]}], ",", 
     RowBox[{"\"\<m\>\"", "->", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<ElectronMass\>\"", "]"}], 
        ",", "\"\<SIBase\>\""}], "]"}]}], ",", 
     RowBox[{"\"\<c\>\"", "->", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<SpeedOfLight\>\"", "]"}], 
        ",", "\"\<SIBase\>\""}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<\[Eta]\>\"", ":>", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"physicalConstants", "[", "\"\<e\>\"", "]"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", 
          RowBox[{"physicalConstants", "[", "\"\<m\>\"", "]"}]}], ")"}]}], 
       "]"}]}]}], "\[IndentingNewLine]", "|>"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[804]:=",ExpressionUUID->"e03f928b-b4f1-47ad-b546-155565b454d0"],

Cell[TextData[{
 StyleBox["Coding aside:",
  FontWeight->"Bold"],
 "\nNotice we used a RuleDelayed (\[RuleDelayed]) trick to ensure that ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]],ExpressionUUID->
  "86e89102-8781-41ce-8e33-abfac1142ba8"],
 ", which depends on other constants is only evaluated once queried, i.e. \
after the Association has been created and thus able to query the other \
constants."
}], "CodeText",
 CellChangeTimes->{{3.978510900763685*^9, 3.9785109353637037`*^9}, {
   3.978511029996626*^9, 3.978511089715088*^9}, {3.978512431404625*^9, 
   3.97851252753944*^9}, 
   3.978534779921962*^9},ExpressionUUID->"e12dcdc3-09e9-49b4-9370-\
2763f7224351"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Analytical Axial Fields", "Section",
 CellChangeTimes->{{3.981539548470335*^9, 
  3.981539556074211*^9}},ExpressionUUID->"9a75efc4-2fa7-45a9-ba63-\
af3adc5dfd41"],

Cell["\<\
To build intuition and enable reproducible calculations, we begin by working \
with analytical expressions for the on-axis fields of idealized electron \
lenses. 
These models capture the essential physics of focusing while remaining simple \
enough to manipulate symbolically and solve numerically.\
\>", "Text",
 CellChangeTimes->{{3.9815395659507236`*^9, 
  3.981539568200706*^9}},ExpressionUUID->"de960787-6fbe-49a8-a5bb-\
d5f1a323c572"],

Cell[CellGroupData[{

Cell["Electrostatic round lens (Schiske field)", "Subsection",
 CellChangeTimes->{
  3.978511401940259*^9},ExpressionUUID->"7f327fee-5765-40a9-ae5b-\
69e898b25f76"],

Cell[TextData[{
 "For electrostatic focusing, we use the ",
 "Schiske potential",
 ", an analytical model for the on-axis electrostatic potential of an \
Einzel-type lens:\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Phi]", 
          StyleBox["Schiske", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox["\[Phi]", "0"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             FractionBox[
              SuperscriptBox[
               StyleBox["k", "TI"], "2"], 
              RowBox[{"1", "+", 
                SuperscriptBox[
                 RowBox[{"(", 
                   RowBox[{
                    StyleBox["z", "TI"], "/", 
                    StyleBox["a", "TI"]}], ")"}], "2"]}]]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi_{\\mathrm{Schiske}}(z)\n= \\phi_0\n\\left(\n1 - \\frac{k^2}{1 + \
\\left(z/a\\right)^2}\n\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d456869f-8e77-4712-a5b6-b842126d490e"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", "0"], TraditionalForm]],ExpressionUUID->
  "5099525d-7880-450d-a900-ef72892eca2b"],
 " is the accelerating potential far from the lens, ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "345da745-a099-4961-a3de-640538639e20"],
 " controls the strength of the electrostatic focusing, and ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "6ce4abd2-5eaf-4e6a-b1d2-51bc98e8a2d6"],
 " sets the axial extent of the lens region.\n\nPhysically, this potential \
corresponds to an ",
 "Einzel lens",
 ": a three-electrode electrostatic lens in which the entrance and exit \
electrodes are held at the same potential, while the central electrode is \
biased. \nElectrons are decelerated and re-accelerated as they traverse the \
lens, producing focusing without a net change in beam energy."
}], "Text",
 CellChangeTimes->{{3.97851140363932*^9, 3.978511517029565*^9}, {
   3.978512337365177*^9, 3.978512338779359*^9}, 
   3.9815396892787323`*^9},ExpressionUUID->"dc2737bf-5071-470a-aac1-\
fd3dc493e01f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"electrostaticField", "[", "\"\<schiske\>\"", "]"}], "[", 
     RowBox[{"a_", ",", "k_", ",", "\[Phi]0_"}], "]"}], "[", "z_", "]"}], "=", 
   RowBox[{"\[Phi]0", " ", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      FractionBox[
       SuperscriptBox["k", "2"], 
       RowBox[{"1", "+", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox["z", "a"], ")"}], "2"]}]]}], ")"}]}]}], ";"}]], "Input",\

 InitializationCell->True,
 CellChangeTimes->{{3.978511558157518*^9, 3.9785115694505157`*^9}},
 CellLabel->
  "In[805]:=",ExpressionUUID->"0b083ec6-a5e2-4c49-a7e1-f7ceb8145b34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"schiskeGraphics", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"a", "=", "0.025"}], ",", 
      RowBox[{"\[Phi]0", " ", "=", " ", "5"}], ",", " ", 
      RowBox[{"k", " ", "=", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Plot", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Phi]0", "-", 
       RowBox[{
        RowBox[{
         RowBox[{"electrostaticField", "[", "\"\<schiske\>\"", "]"}], "[", 
         RowBox[{"a", ",", "k", ",", " ", "\[Phi]0"}], "]"}], "[", "z", 
        "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", 
        RowBox[{"-", "0.5"}], ",", "0.5"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<axial position, z(m)\>\"", 
         ",", "\"\<electrostatic field, \[Phi](V)\>\""}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"FrameStyle", "->", "16"}], ",", "\[IndentingNewLine]", 
      RowBox[{"ImageSize", "->", "600"}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.97851168758322*^9, 3.978511761214568*^9}, {
  3.9815395842981243`*^9, 3.98153961176803*^9}, {3.9815396581771193`*^9, 
  3.9815396604725018`*^9}},
 CellLabel->
  "In[808]:=",ExpressionUUID->"61536665-22db-4925-ac26-8814552fd094"],

