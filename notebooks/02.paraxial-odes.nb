Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"paraxialSolution", "[", "\"\<glaser\>\"", "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"a", "=", "0.0075"}], ",", "\[IndentingNewLine]", 
       RowBox[{"B0", "=", "0.01"}], ",", "\[IndentingNewLine]", 
       RowBox[{"\[Phi]0", "=", "1000"}], ",", "\[IndentingNewLine]", 
       RowBox[{"startPosition", " ", "=", " ", 
        RowBox[{"-", "0.1"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"endPosition", " ", "=", " ", "0.1"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Eta]", "=", 
        RowBox[{"physicalConstants", "[", "\"\<\[Eta]\>\"", "]"}]}]}], 
      "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"ParametricNDSolveValue", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"linearizedODE", "[", 
           RowBox[{"\[Phi]0", ",", "\[Eta]"}], "]"}], "[", 
          RowBox[{
           RowBox[{"magneticField", "[", "\"\<glaser\>\"", "]"}], "[", 
           RowBox[{"a", ",", "B0"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"r", "[", "startPosition", "]"}], " ", "==", " ", 
          "initialTransverseDisplacement"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "startPosition", "]"}], "==", 
          "initialSlope"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"r", "[", "z", "]"}], "==", "0"}], "&&", 
            RowBox[{"z", ">", "0"}]}], ",", 
           RowBox[{"Sow", "[", "z", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
        "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", "r", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "startPosition", ",", "endPosition"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"initialTransverseDisplacement", ",", "initialSlope"}], "}"}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"Method", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<ParametricCaching\>\"", "\[Rule]", "None"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[812]:=",ExpressionUUID->"ff662186-445c-4695-b7a9-60429d06589b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"primaryRay", "[", "\"\<glaser\>\"", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"focalPlane", "[", "\"\<glaser\>\"", "]"}], "}"}], "}"}]}], 
    "}"}], "=", 
   RowBox[{"Reap", "[", 
    RowBox[{
     RowBox[{"paraxialSolution", "[", "\"\<glaser\>\"", "]"}], "[", 
     RowBox[{"1", ",", "0"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"marginalRay", "[", "\"\<glaser\>\"", "]"}], ",", 
