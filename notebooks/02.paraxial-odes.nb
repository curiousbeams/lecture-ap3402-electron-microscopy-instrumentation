Cell[BoxData[
 RowBox[{
  RowBox[{"apertureEvents", "[", "apertures_List", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "z"}], "}"}], ",", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"zAp", "=", 
           RowBox[{"ap", "[", "\"\<axial_position\>\"", "]"}]}], ",", 
          RowBox[{"R", "=", 
           RowBox[{"ap", "[", "\"\<aperture_radius\>\"", "]"}]}]}], "}"}], ",", 
        RowBox[{"WhenEvent", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"z", "-", "zAp"}], "==", "0"}], "&&", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"r", "[", "z", "]"}], "]"}], ">", "R"}]}], 
          ",", "\"\<StopIntegration\>\"", ",", 
          
          RowBox[{"\"\<LocationMethod\>\"", 
           "->", "\"\<LinearInterpolation\>\""}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"ap", ",", "apertures"}], "}"}]}], "]"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[903]:=",ExpressionUUID->"cfda2dab-9503-4175-a7e0-933f9df72688"],

