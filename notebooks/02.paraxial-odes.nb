9a6892521f18"],

Cell[TextData[{
 "A widely used model for the axial magnetic field of a rotationally \
symmetric magnetic lens is the ",
 StyleBox["Glaser bell-shaped field",
  FontWeight->"Bold"],
 ", given by\n\t",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["B", "TI"], 
         StyleBox["Glaser", FontSlant -> "Plain"]], 
        RowBox[{"(", 
          StyleBox["z", "TI"], ")"}], "\[LongEqual]", 
        FractionBox[
         SubscriptBox[
          StyleBox["B", "TI"], "0"], 
         RowBox[{"1", "+", 
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{
                StyleBox["z", "TI"], "/", 
                StyleBox["a", "TI"]}], ")"}], "2"]}]]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "B_{\\mathrm{Glaser}}(z)\n= \\frac{B_0}{1 + \\left(z/a\\right)^2}", 
    "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "b8cb4019-1b0d-4fd9-b1b3-478e3b7ded80"],
 ", \nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "0"], TraditionalForm]],ExpressionUUID->
  "5c17e1cd-594d-4761-872e-dd135c5e7d37"],
 " is the peak axial magnetic field strength, and ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "60eb7b4e-a6f0-439d-b919-671742471d8b"],
 " sets the effective half-width of the lens and controls how rapidly the \
field falls off along the optic axis.\n\nThis field approximates the axial \
field produced by a solenoidal magnetic lens with finite pole-piece \
separation. While it does not correspond to an exact coil geometry, it \
closely reproduces the focusing properties of practical magnetic round lenses \
and is widely used in analytical aberration theory."
}], "Text",
 CellChangeTimes->{{3.978511166278163*^9, 3.978511174556013*^9}, {
  3.978511255940258*^9, 3.978511336956813*^9}, {3.9785123408506193`*^9, 
  3.978512341787375*^9}},ExpressionUUID->"98973ce5-b665-432b-b012-\
6bd571df20ef"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"magneticField", "[", "\"\<glaser\>\"", "]"}], "[", 
     RowBox[{"a_", ",", "B0_"}], "]"}], "[", "z_", "]"}], "=", 
   RowBox[{"B0", "/", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["z", "a"], ")"}], "2"]}], ")"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978511353648943*^9, 3.9785113869389477`*^9}, 
   3.978511554330997*^9},
 CellLabel->
  "In[809]:=",ExpressionUUID->"5af75176-537f-4257-8c38-cee56ce744e0"],

Cell[CellGroupData[{

