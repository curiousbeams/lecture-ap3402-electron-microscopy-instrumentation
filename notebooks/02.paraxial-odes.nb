Cell[CellGroupData[{

Cell["Paraxial Ray Solutions", "Section",
 CellChangeTimes->{{3.981539768486767*^9, 
  3.981539772264398*^9}},ExpressionUUID->"9d84a99e-429f-4c98-983b-\
a37dd54933d1"],

Cell[TextData[{
 "The paraxial ray equation derived in the previous section is a ",
 StyleBox["linear, second-order ordinary differential equation",
  FontWeight->"Bold"],
 " in the transverse coordinate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", "z", ")"}], TraditionalForm]],ExpressionUUID->
  "90ef1585-6992-4c23-a3cd-6c57b9040bdd"],
 ". As a consequence, its solution space is two-dimensional: any paraxial ray \
trajectory can be written as a linear combination of two linearly independent \
solutions.\n\nIt is therefore natural to choose a convenient basis of \
solutions with a clear physical interpretation. In electron optics, these are \
known as the ",
 StyleBox["primary ray",
  FontWeight->"Bold"],
 " and the ",
 StyleBox["marginal ray",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{
  3.981539780562337*^9},ExpressionUUID->"b337ba08-6469-4515-a071-\
ee98ca32a861"],

Cell[CellGroupData[{

Cell["Primary Ray", "Subsection",
 CellChangeTimes->{{3.981539786711218*^9, 
  3.9815397924543343`*^9}},ExpressionUUID->"cef8d128-133d-4943-ae6e-\
44bd2fed97d8"],

Cell[TextData[{
 "The ",
 StyleBox["primary ray",
  FontWeight->"Bold"],
 " describes the trajectory of a ray that starts with a finite transverse \
displacement but zero initial slope:\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], "0"], ")"}], "\[LongEqual]", "1", ",    ", 
         SuperscriptBox[
          StyleBox["g", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], "0"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g(z_0) = 1, \\qquad g'(z_0) = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9af4fdd5-bfdd-43de-8699-5abaedebb255"],
 "\nPhysically, this corresponds to a ray that originates off-axis but \
initially travels parallel to the optic axis. \nThe primary ray encodes how \
transverse positions in the object plane are imaged by the lens."
}], "Text",
 CellChangeTimes->{{3.981539797807991*^9, 
  3.981539801383175*^9}},ExpressionUUID->"79b018e9-ac38-4610-8315-\
1c5085a489ec"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Marginal Ray", "Subsection",
 CellChangeTimes->{{3.981539806262191*^9, 
  3.981539808599422*^9}},ExpressionUUID->"84c1ffb0-b3c5-4d2d-8890-\
51a48e89c82c"],

Cell[TextData[{
 "The ",
 StyleBox["marginal ray",
  FontWeight->"Bold"],
 " describes the trajectory of a ray that starts on-axis but with a finite \
initial angle:\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], "0"], ")"}], "\[LongEqual]", "0", ",    ", 
         SuperscriptBox[
          StyleBox["h", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], "0"], ")"}], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "h(z_0) = 0, \\qquad h'(z_0) = 1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "01f38366-b496-4d86-a1ef-76e8fabe1715"],
 "\nThis ray represents the extreme ray in an angular pencil and encodes how \
angles at the object plane are transformed by the lens."
}], "Text",
 CellChangeTimes->{
  3.981539813018965*^9},ExpressionUUID->"9d7b1ed8-4a28-48b3-91a5-\
329ec2bd44c0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Solution", "Subsection",
 CellChangeTimes->{{3.981539817383177*^9, 
  3.981539821016243*^9}},ExpressionUUID->"be97c955-fc5d-46a3-b1a7-\
c034b3512232"],

Cell[TextData[{
 "Because the paraxial equation is linear, ",
 StyleBox["any paraxial ray",
  FontWeight->"Bold"],
 " with initial conditions\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], "0"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["r", "TI"], "0"], ",    ", 
         SuperscriptBox[
          StyleBox["r", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], "0"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["r", "TI"], "0", "\[Prime]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "r(z_0) = r_0, \\qquad r'(z_0) = r_0'", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f647f8e3-d298-4a17-a8ef-b2bd69cdcba4"],
 "\ncan be written as a linear combination of the primary and marginal rays:\n\
\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["r", "TI"], "0"], " ", 
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "+", 
         SubsuperscriptBox[
          StyleBox["r", "TI"], "0", "\[Prime]"], " ", 
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r(z) = r_0\\, g(z) + r_0'\\, h(z)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cbf2d4f5-bc77-4a2c-b063-0fdaeb61d5a8"],
 ".\nThis decomposition makes the role of each ray explicit: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", "z", ")"}], TraditionalForm]],ExpressionUUID->
  "73ff6f1e-508e-4e3f-9aa1-31fd5ca51b4e"],
 " propagates transverse position; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "(", "z", ")"}], TraditionalForm]],ExpressionUUID->
  "461b4676-4c0a-416a-b821-0c095f6aee82"],
 " propagates angular deviation."
}], "Text",
 CellChangeTimes->{
  3.98153982563157*^9},ExpressionUUID->"b4aaf9dd-feef-4101-a94f-e5eb4d6e881c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Linear Imaging Properties", "Subsection",
 CellChangeTimes->{{3.9815398328731956`*^9, 
  3.9815398364006977`*^9}},ExpressionUUID->"c392cc04-99f4-417c-bad7-\
85f04c68a950"],

Cell["\<\
Once the primary and marginal rays are known, the fundamental linear imaging \
properties of the lens follow directly.\
\>", "Text",
 CellChangeTimes->{
  3.981539840479504*^9},ExpressionUUID->"c34da88c-cddb-40a4-968b-\
a37327f5594b"],

Cell[CellGroupData[{

Cell["Focal plane", "Subsubsection",
 CellChangeTimes->{{3.981539854064128*^9, 
  3.98153985941656*^9}},ExpressionUUID->"4018d649-8bbf-49f5-a58e-\
12ccc043e4c4"],

Cell[TextData[{
 "The ",
 StyleBox["focal plane",
  FontWeight->"Bold"],
 " is defined as the axial position where a ray entering parallel to the \
optic axis is brought to a focus. \nThis corresponds to the zero crossing of \
the primary ray: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["f", "TI"]], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "g(z_f) = 0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3693577d-4a6a-49bc-aa0d-a4ea1632ffe8"],
 ". The focal length is then measured relative to the chosen reference \
plane."
}], "Text",
 CellChangeTimes->{{3.981539861180656*^9, 
  3.981539863470603*^9}},ExpressionUUID->"1c79191e-81c6-4833-80dd-\
89c2f5876483"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Image plane", "Subsubsection",
 CellChangeTimes->{
  3.9815398692974157`*^9},ExpressionUUID->"adc433eb-7774-4cc7-883d-\
2853ebb1cf0c"],

Cell[TextData[{
 "The ",
 StyleBox["image plane",
  FontWeight->"Bold"],
 " is defined as the axial position where a point source on the optic axis is \
imaged to a point. This corresponds to the zero crossing of the marginal ray: \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["i", "TI"]], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "h(z_i) = 0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "84dc4ab4-2158-46af-9389-a0518be2cb09"],
 ". \nAt this plane, rays emerging from a single object point intersect again."
}], "Text",
 CellChangeTimes->{{3.981539875080471*^9, 
  3.9815398795608807`*^9}},ExpressionUUID->"d3a2aaf3-82d1-42fa-8c5f-\
75f3160e6ce8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Magnification", "Subsubsection",
 CellChangeTimes->{
  3.981539885418532*^9},ExpressionUUID->"604fe000-5996-45c8-9b8e-\
59499fa28bff"],

Cell[TextData[{
 "The transverse magnification is given by the value of the primary ray \
evaluated at the image plane: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "\[LongEqual]", 
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["i", "TI"]], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "M = g(z_i)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f15987d6-4244-41cb-bffd-6925fed7cc9e"],
 ". \nThis follows directly from the general solution: a point at transverse \
position ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "0"], TraditionalForm]],ExpressionUUID->
  "c632bafe-87e2-48ed-85f1-1ccdb6fe14c6"],
 " in the object plane is mapped to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["i", "TI"]], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["r", "TI"], "0"], " ", 
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["i", "TI"]], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r(z_i) = r_0\\, g(z_i)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "151ef24b-e491-431a-9faa-cce1a5472dcc"],
 " in the image plane."
}], "Text",
 CellChangeTimes->{{3.981539889802809*^9, 
  3.98153989283134*^9}},ExpressionUUID->"7761d8e6-5117-498d-ba12-\
072c07f72d0a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"paraxialSolution", "[", "\"\<schiske\>\"", "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"a", "=", "0.025"}], ",", "\[IndentingNewLine]", 
       RowBox[{"\[Phi]0", "=", "5"}], ",", "\[IndentingNewLine]", 
       RowBox[{"k", "=", 
        RowBox[{"1", "/", 
         RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"startPosition", " ", "=", " ", 
        RowBox[{"-", "0.5"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"endPosition", " ", "=", " ", "1.0"}]}], "\[IndentingNewLine]",
       "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"ParametricNDSolveValue", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"linearizedODE", "[", "\[Phi]0", "]"}], "[", 
          RowBox[{
           RowBox[{"electrostaticField", "[", "\"\<schiske\>\"", "]"}], "[", 
           RowBox[{"a", ",", "k", ",", "\[Phi]0"}], "]"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"r", "[", "startPosition", "]"}], " ", "==", " ", 
          "initialTransverseDisplacement"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "startPosition", "]"}], "==", 
          "initialSlope"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"r", "[", "z", "]"}], "==", "0"}], "&&", 
            RowBox[{"z", ">", "0"}]}], ",", 
           RowBox[{"Sow", "[", "z", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
