     RowBox[{"paraxialSolution", "[", "\"\<glaser\>\"", "]"}], "[", 
     RowBox[{"0", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"magnification", "[", "\"\<glaser\>\"", "]"}], " ", "=", " ", 
  RowBox[{
