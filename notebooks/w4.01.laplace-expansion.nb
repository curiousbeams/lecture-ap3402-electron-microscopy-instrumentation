      RowBox[{"[", "#", "]"}], "]"}], "&"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}], "=", " ", 
   RowBox[{"Join", "@@", 
    RowBox[{"electrodeCoords", "[", "\"\<all\>\"", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}], "=", 
   RowBox[{"Map", "[", 
    RowBox[{"Reverse", ",", 
     RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"duplicatePositions", "=", 
   RowBox[{"positionDuplicates", "[", 
    RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}], "=", 
    RowBox[{"DeleteDuplicates", "[", 
     RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "makeSequentialLineElements", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"makeSequentialLineElements", "[", 
    RowBox[{"l_", ",", 
     RowBox[{"offset_", ":", "0"}]}], "]"}], ":=", 
   RowBox[{"LineElement", "[", 
    RowBox[{"Partition", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"Range", "[", "l", "]"}], ",", "1"}], "]"}], "+", "offset"}],
       ",", "2", ",", "1"}], "]"}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"removeDuplicatesAndRenumber", "[", 
    RowBox[{"elements_", ",", "duplicates_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "allIndices", ",", "mergeMap", ",", "uniqueIndices", ",", "reindexMap", 
       ",", "finalRules"}], "}"}], ",", 
     RowBox[{
      RowBox[{"mergeMap", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Rest", "[", "#", "]"}], "->", 
            RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
         "duplicates"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"allIndices", "=", 
       RowBox[{"Range", "[", 
        RowBox[{"Max", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"elements", "/.", " ", 
           RowBox[{"LineElement", "->", "Identity"}]}], "]"}], "]"}], "]"}]}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"uniqueIndices", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{"allIndices", ",", 
         RowBox[{"List", "/@", 
          RowBox[{"Keys", "[", "mergeMap", "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"reindexMap", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{"uniqueIndices", "->", 
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "uniqueIndices", "]"}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"finalRules", "=", 
       RowBox[{"Dispatch", "[", "\[IndentingNewLine]", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"mergeMap", "/.", " ", "reindexMap"}], ",", 
          "\[IndentingNewLine]", "reindexMap"}], "\[IndentingNewLine]", "]"}],
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"elements", "/.", " ", "finalRules"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lengths", "=", 
   RowBox[{"Length", "/@", 
    RowBox[{"electrodeCoords", "[", "\"\<all\>\"", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"offsets", "=", 
    RowBox[{
     RowBox[{"Accumulate", "[", 
      RowBox[{"Prepend", "[", 
       RowBox[{"lengths", ",", "0"}], "]"}], "]"}], "//", "Most"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"boundaryElements", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{"makeSequentialLineElements", ",", 
     RowBox[{"{", 
      RowBox[{"lengths", ",", "offsets"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"boundaryElements", "=", 
   RowBox[{"removeDuplicatesAndRenumber", "[", 
    RowBox[{"boundaryElements", ",", "duplicatePositions"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"boundaryElements", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{"Append", ",", 
     RowBox[{"{", 
      RowBox[{"boundaryElements", ",", 
       RowBox[{"Range", "[", 
        RowBox[{"Length", "[", "boundaryElements", "]"}], "]"}]}], "}"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"bmesh", "=", 
    RowBox[{"ToBoundaryMesh", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\"\<Coordinates\>\"", "->", 
       RowBox[{"electrodeCoords", "[", "\"\<flat\>\"", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<BoundaryElements\>\"", "->", "boundaryElements"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"refinementFunction", "[", 
    RowBox[{"vertices_", ",", "area_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "centroid", ",", "r", ",", "z", ",", "distToAxis", ",", "distToBottom", 
       ",", "targetArea"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"centroid", "=", 
       RowBox[{"Mean", "[", "vertices", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"r", "=", 
       RowBox[{"centroid", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"z", "=", 
       RowBox[{"centroid", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"distToAxis", "=", 
       RowBox[{"Abs", "[", "r", "]"}]}], ";", 
      RowBox[{"targetArea", "=", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"distToAxis", "<", "0.002"}], ",", 
         RowBox[{"0.5", "*", 
          RowBox[{"10", "^", 
           RowBox[{"-", "8"}]}]}], ",", "True", ",", 
         RowBox[{"5.0", "*", 
          RowBox[{"10", "^", 
           RowBox[{"-", "6"}]}]}]}], " ", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"area", ">", "targetArea"}]}]}], "\[IndentingNewLine]", "]"}]}],
   "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"emesh", "=", 
    RowBox[{"ToElementMesh", "[", "\[IndentingNewLine]", 
     RowBox[{"bmesh", ",", "\[IndentingNewLine]", 
      RowBox[{"MeshRefinementFunction", "->", "refinementFunction"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"MaxCellMeasure", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<Area\>\"", "->", 
         RowBox[{"5", "*", 
          RowBox[{"10", "^", 
           RowBox[{"-", "6"}]}]}]}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<MeshOrder\>\"", "->", "2"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"limeColor", "=", 
   RowBox[{"RGBColor", "[", 
    RowBox[{
     RowBox[{"211", "/", "255"}], ",", 
     RowBox[{"225", "/", "255"}], ",", 
     RowBox[{"115", "/", "255"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cyanColor", "=", 
   RowBox[{"RGBColor", "[", 
    RowBox[{
     RowBox[{"155", "/", "255"}], ",", "1", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"amberColor", "=", 
   RowBox[{"RGBColor", "[", 
    RowBox[{"1", ",", 
     RowBox[{"191", "/", "255"}], ",", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pinkColor", "=", 
    RowBox[{"RGBColor", "[", 
     RowBox[{"1", ",", 
      RowBox[{"47", "/", "85"}], ",", 
      RowBox[{"161", "/", "255"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"graphics", "=", 
  RowBox[{"bmesh", "[", "\[IndentingNewLine]", 
   RowBox[{"\"\<Wireframe\>\"", "[", "\[IndentingNewLine]", 
    RowBox[{"\"\<MeshElementStyle\>\"", "->", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"AbsoluteThickness", "[", "1", "]"}], ",", "#"}], "]"}], 
        "&"}], "/@", 
       RowBox[{"{", 
        RowBox[{
        "limeColor", ",", "amberColor", ",", "cyanColor", ",", "cyanColor", ",",
          "cyanColor", ",", "pinkColor"}], "}"}]}], ")"}]}], 
    "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.981531662356745*^9, 3.981531670372705*^9}, {
