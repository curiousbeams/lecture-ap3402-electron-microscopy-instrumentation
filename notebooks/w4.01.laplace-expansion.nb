Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"harmonicField", "[", 
    RowBox[{"r_", ",", "z_"}], "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"phi", "=", "phiSol"}], ",", "\[IndentingNewLine]", 
       RowBox[{"phi2", "=", 
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", "2"}], "]"}], "[", "phiSol", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"phi4", "=", 
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", "4"}], "]"}], "[", "phiSol", "]"}]}]}], 
      "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"phi", "[", 
       RowBox[{"0", ",", "z"}], "]"}], "-", 
      RowBox[{
       RowBox[{
        SuperscriptBox["r", "2"], "/", "4"}], " ", 
       RowBox[{"phi2", "[", 
        RowBox[{"0", ",", "z"}], "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{
        SuperscriptBox["r", "4"], "/", "64"}], " ", 
       RowBox[{"phi4", "[", 
        RowBox[{"0", ",", "z"}], "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[707]:=",ExpressionUUID->"48f5718f-3a9e-4554-b063-8a7ae1b562ec"],

