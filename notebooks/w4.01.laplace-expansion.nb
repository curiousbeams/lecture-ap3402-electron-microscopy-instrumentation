Cell["\<\
We set-up the Laplace equation, using Dirichlet boundary conditions, fixing \
the potential value at the electrode boundaries:\
\>", "Text",
 CellChangeTimes->{{3.981533587096094*^9, 3.9815335920233383`*^9}, {
  3.9815336307206993`*^9, 
  3.981533665234112*^9}},ExpressionUUID->"e193eb8e-985b-4453-aab9-\
e939d3ebbdde"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"voltages", "=", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<left\>\"", "->", "0"}], ",", 
     RowBox[{"\"\<middle-left\>\"", "->", "500"}], ",", 
     RowBox[{"\"\<middle\>\"", "->", "500"}], ",", 
     RowBox[{"\"\<middle-right\>\"", "->", "500"}], ",", 
     RowBox[{"\"\<right\>\"", "->", "0"}]}], "\[IndentingNewLine]", "|>"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bcs", "=", 
    RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"DirichletCondition", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"phi", "[", 
           RowBox[{"r", ",", "z"}], "]"}], "==", "#1"}], ",", 
         RowBox[{"ElementMarker", "==", "#2"}]}], "]"}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Values", "[", "voltages", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"2", ",", "3", ",", "4", ",", "5", ",", "6"}], "}"}]}], 
       "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"op", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Div", "]"}], "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "r"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"-", "r"}]}], "}"}]}], "}"}], ".", 
      RowBox[{
       RowBox[{"Inactive", "[", "Grad", "]"}], "[", 
       RowBox[{
        RowBox[{"phi", "[", 
         RowBox[{"r", ",", "z"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "z"}], "}"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "z"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"phiSol", "=", 
   RowBox[{"NDSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"op", "==", "0"}], ",", "bcs"}], "}"}], ",", "phi", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r", ",", "z"}], "}"}], "\[Element]", " ", "emesh"}]}], 
    "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9815336800254507`*^9, 3.981533680349585*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"7f3c6ea8-f066-4e37-942b-7caffcd89feb"],

Cell["We can plot the numerical solution on the optical axis", "Text",
 CellChangeTimes->{{3.981533708470571*^9, 
  3.981533759826*^9}},ExpressionUUID->"1ab8e8df-6eec-49a0-aa60-08d7d8460ce6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"axialField", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{"phiSol", "[", 
      RowBox[{"0", ",", "z"}], "]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", 
      RowBox[{"-", "0.04"}], ",", "0.04"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<axial position, z (m)\>\"", 
       ",", "\"\<electrostatic potential, \[CapitalPhi] (V)\>\""}], "}"}]}]}],
    "]"}]}]], "Input",
 CellChangeTimes->{{3.981533806418599*^9, 3.981533861297118*^9}, {
  3.9815345056114597`*^9, 3.981534507067409*^9}},
 CellLabel->
  "In[722]:=",ExpressionUUID->"6e155898-1267-498b-8c0b-64ea7357563a"],

