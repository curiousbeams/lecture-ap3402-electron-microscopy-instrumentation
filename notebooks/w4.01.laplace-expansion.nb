Notebook[{

Cell[CellGroupData[{
Cell["Physics of Electron Microscopy Instrumentation", "Title",
 CellChangeTimes->{{3.9814466515808773`*^9, 
  3.9814466605467*^9}},ExpressionUUID->"2521197b-e264-4f0f-83f9-50d9b8fa3153"],

Cell["Georgios Varnavides | March 3rd 2026", "Subtitle",
 CellChangeTimes->{{3.9814466652477837`*^9, 3.9814466774444857`*^9}, {
  3.981515052417898*^9, 
  3.981515055711447*^9}},ExpressionUUID->"3aa9ca14-c97f-43b2-b9d9-\
af4ef0447aae"],

Cell[CellGroupData[{

Cell["Axial Fields & Laplace Equation", "Chapter",
 CellChangeTimes->{{3.981446681326468*^9, 3.9814466939325247`*^9}, {
  3.9815150782497253`*^9, 
  3.98151508380159*^9}},ExpressionUUID->"16d427f6-928a-476e-ab16-\
fa3f754f86d4"],

Cell[CellGroupData[{

Cell["Maxwell & Laplace Symmetries", "Section",
 CellChangeTimes->{{3.981515102329373*^9, 
  3.9815151196089907`*^9}},ExpressionUUID->"70a8df9d-2eda-4974-bc16-\
efd6a6c81e25"],

Cell["\<\
In the previous lecture, we postulated how electromagnetic focusing depends \
solely on axial electrostatic and magnetic fields and their gradients.

It might not be immediately obvious why that is the case, so here we briefly \
expand on the derivation.\
\>", "Text",
 CellChangeTimes->{{3.981534935896571*^9, 
  3.981534937602353*^9}},ExpressionUUID->"02b6a3b9-d470-48e6-87ce-\
967ffd19d2e5"],

Cell[CellGroupData[{

Cell["Cylindrical Symmetry Laplace", "Subsection",
 CellChangeTimes->{{3.981516046209776*^9, 
  3.981516054505867*^9}},ExpressionUUID->"36f5f4e3-b9dd-43d0-bba9-\
071161d5d039"],

Cell[TextData[{
 "In the source-free region of a round electrostatic (or magnetic) lens:\n\n\t\
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Del]", "\[CenterDot]", 
         StyleBox["E", FontSlant -> "Bold"], "\[LongEqual]", "0", ",    ", 
         "\[Del]", "\[Cross]", 
         StyleBox["E", FontSlant -> "Bold"], "\[LongEqual]", "0."}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\nabla \\cdot \\mathbf{E} = 0,\n\\qquad\n\\nabla \\times \\mathbf{E} = \
0.", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8b12f6b0-a6ce-49a2-aac0-a1b296ded9a5"],
 "\n\nTherefore\n\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["E", FontSlant -> "Bold"], "\[LongEqual]", "-", "\[Del]", 
         "\[CapitalPhi]", ",    ", 
         SuperscriptBox["\[Del]", "2"], "\[CapitalPhi]", "\[LongEqual]", 
         "0."}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mathbf{E} = -\\nabla \\Phi,\n\\qquad\n\\nabla^2 \\Phi = 0.", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1487abcd-a5e5-4270-8e2c-643e4b8b4bf7"],
 "\n\nWith cylindrical symmetry (",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
        "\[PartialD]", "/", "\[PartialD]", "\[Phi]", "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\partial/\\partial\\phi = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2681651c-54c3-450f-9acd-dfd6562a1c0d"],
 "):\n\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["1", 
          StyleBox["r", "TI"]], 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["r", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], 
             FractionBox[
              RowBox[{"\[PartialD]", "\[CapitalPhi]"}], 
              RowBox[{"\[PartialD]", 
                StyleBox["r", "TI"]}]]}], ")"}], "+", 
         FractionBox[
          RowBox[{
            SuperscriptBox["\[PartialD]", "2"], "\[CapitalPhi]"}], 
          RowBox[{"\[PartialD]", 
            SuperscriptBox[
             StyleBox["z", "TI"], "2"]}]], "\[LongEqual]", "0."}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{1}{r}\\frac{\\partial}{\\partial r}\n\\left(r \\frac{\\partial \
\\Phi}{\\partial r}\\right)\n+\n\\frac{\\partial^2 \\Phi}{\\partial z^2}\n= \
0.", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b1c5b6a4-98e3-4804-ba0e-5d64a25def0c"],
 "\n\t\nWhich suggests the potential is harmonic and therefore analytic near \
the optic axis."
}], "Text",
 CellChangeTimes->{{3.9815151292278748`*^9, 
  3.981515262816505*^9}},ExpressionUUID->"0f107a7b-587c-4ec1-8b1f-\
7a618114ded3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Laplacian", "[", 
  RowBox[{
   RowBox[{"\[Phi]", "[", 
    RowBox[{"r", ",", "z"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "\[Theta]", ",", "z"}], "}"}], 
   ",", "\"\<Cylindrical\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.9815153175176*^9, 3.9815153184986353`*^9}, {
  3.981515544459178*^9, 3.9815155472056637`*^9}, {3.981515593242998*^9, 
  3.981515624314352*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"1fe1f1e0-8add-42bb-973e-4a1a80ad98b7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[Phi]", 
    TagBox[
     RowBox[{"(", 
      RowBox[{"0", ",", "2"}], ")"}],
     Derivative],
    MultilineFunction->None], "[", 
   RowBox[{"r", ",", "z"}], "]"}], "+", 
  FractionBox[
   RowBox[{
    SuperscriptBox["\[Phi]", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"1", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"r", ",", "z"}], "]"}], "r"], "+", 
  RowBox[{
   SuperscriptBox["\[Phi]", 
    TagBox[
     RowBox[{"(", 
      RowBox[{"2", ",", "0"}], ")"}],
     Derivative],
    MultilineFunction->None], "[", 
   RowBox[{"r", ",", "z"}], "]"}]}]], "Output",
 CellChangeTimes->{3.981515312111103*^9, 3.981515403119014*^9, 
  3.9815155474491463`*^9, 3.981515595638391*^9, 3.9815156435560904`*^9},
 CellLabel->"Out[15]=",ExpressionUUID->"a9c0bc4f-9270-48d8-8985-905e4ed3e21c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"\[Phi]", "[", 
          RowBox[{"r", ",", "z"}], "]"}], ",", "r"}], "]"}]}], ",", "r"}], 
     "]"}], "/", "r"}], " ", "+", " ", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[Phi]", "[", 
      RowBox[{"r", ",", "z"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", "2"}], "}"}]}], "]"}]}], "//", "Simplify"}]], "Input",\

 CellChangeTimes->{{3.981515645171131*^9, 3.981515683745697*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"41899ad1-62c5-4c84-816b-7376f4dee6f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[Phi]", 
    TagBox[
     RowBox[{"(", 
      RowBox[{"0", ",", "2"}], ")"}],
     Derivative],
    MultilineFunction->None], "[", 
   RowBox[{"r", ",", "z"}], "]"}], "+", 
  FractionBox[
   RowBox[{
    SuperscriptBox["\[Phi]", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"1", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"r", ",", "z"}], "]"}], "r"], "+", 
  RowBox[{
   SuperscriptBox["\[Phi]", 
    TagBox[
     RowBox[{"(", 
      RowBox[{"2", ",", "0"}], ")"}],
     Derivative],
    MultilineFunction->None], "[", 
   RowBox[{"r", ",", "z"}], "]"}]}]], "Output",
 CellChangeTimes->{{3.9815156587690763`*^9, 3.981515684625902*^9}},
 CellLabel->"Out[19]=",ExpressionUUID->"24108df1-2c4f-4ea2-8731-d217d60ec9cf"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Analytical Expansion", "Subsection",
 CellChangeTimes->{{3.9815160593929167`*^9, 
  3.981516064376202*^9}},ExpressionUUID->"94f611f8-b4cd-447f-bf75-\
050409b525aa"],

Cell[TextData[{
 "Expanding in powers of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a98b9c7b-bda3-48a8-bfcc-d15fa7c74246"],
 ":\n\t\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalPhi]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], ",", 
             StyleBox["z", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["a", "TI"], "0"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], "1"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], 
         StyleBox["r", "TI"], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], "2"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], "3"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "3"], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], "4"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "4"], "+", "\[CenterEllipsis]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\Phi(r,z)\n=\na_0(z)\n+\na_1(z) r\n+\na_2(z) r^2\n+ a_3(r) r^3 + \
a_4(r) r^4 + \\cdots", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "01382b34-4525-4cac-9f44-9f535a55b314"],
 "\t"
}], "Text",
 CellChangeTimes->{{3.981515277005549*^9, 3.9815152810635853`*^9}, {
  3.98151569477642*^9, 3.981515707564673*^9}, {3.9815160886252947`*^9, 
  3.981516091958334*^9}, {3.981516215988307*^9, 
  3.981516219065999*^9}},ExpressionUUID->"bedc70f0-610b-43da-9044-\
7082e3427e0d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"\[Phi]", "[", 
    RowBox[{"r", ",", "z"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "0", ",", "4"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981515950386031*^9, 3.981515970392776*^9}, {
  3.981516510106998*^9, 3.9815165298819437`*^9}, {3.9815167163553*^9, 
  3.981516718121614*^9}, {3.981529827282269*^9, 3.9815298274258738`*^9}, {
  3.981601569691587*^9, 3.9816015698063383`*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"279165b3-7095-4deb-b95b-bb209fe47147"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{"\[Phi]", "[", 
    RowBox[{"0", ",", "z"}], "]"}], "+", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Phi]", 
      TagBox[
       RowBox[{"(", 
        RowBox[{"1", ",", "0"}], ")"}],
       Derivative],
      MultilineFunction->None], "[", 
     RowBox[{"0", ",", "z"}], "]"}], " ", "r"}], "+", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{
     SuperscriptBox["\[Phi]", 
      TagBox[
       RowBox[{"(", 
        RowBox[{"2", ",", "0"}], ")"}],
       Derivative],
      MultilineFunction->None], "[", 
     RowBox[{"0", ",", "z"}], "]"}], " ", 
    SuperscriptBox["r", "2"]}], "+", 
   RowBox[{
    FractionBox["1", "6"], " ", 
    RowBox[{
     SuperscriptBox["\[Phi]", 
      TagBox[
       RowBox[{"(", 
        RowBox[{"3", ",", "0"}], ")"}],
       Derivative],
      MultilineFunction->None], "[", 
     RowBox[{"0", ",", "z"}], "]"}], " ", 
    SuperscriptBox["r", "3"]}], "+", 
   RowBox[{
    FractionBox["1", "24"], " ", 
    RowBox[{
     SuperscriptBox["\[Phi]", 
      TagBox[
       RowBox[{"(", 
        RowBox[{"4", ",", "0"}], ")"}],
       Derivative],
      MultilineFunction->None], "[", 
     RowBox[{"0", ",", "z"}], "]"}], " ", 
    SuperscriptBox["r", "4"]}], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "r", "]"}], "5"],
    SeriesData[$CellContext`r, 0, {}, 0, 5, 1],
    Editable->False]}],
  SeriesData[$CellContext`r, 0, {
    $CellContext`\[Phi][0, $CellContext`z], 
    Derivative[1, 0][$CellContext`\[Phi]][0, $CellContext`z], Rational[1, 2] 
    Derivative[2, 0][$CellContext`\[Phi]][0, $CellContext`z], Rational[1, 6] 
    Derivative[3, 0][$CellContext`\[Phi]][0, $CellContext`z], Rational[1, 24] 
    Derivative[4, 0][$CellContext`\[Phi]][0, $CellContext`z]}, 0, 5, 1],
  Editable->False]], "Output",
 CellChangeTimes->{{3.9815159553621197`*^9, 3.9815159707425127`*^9}, {
   3.9815165103501997`*^9, 3.981516530226597*^9}, 3.9815167184523067`*^9, 
   3.98152982859834*^9, 3.98160157438864*^9},
 CellLabel->"Out[35]=",ExpressionUUID->"d24f6372-9bb5-4740-98ed-0c486b6f3d9a"]
}, Open  ]],

Cell[TextData[{
 "and noting that due to cylindrical symmetry, the field is invariant under \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[Rule]", "-", 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r \\rightarrow -r", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "25224aac-5812-4d68-bd5c-532cd3992827"],
 ", the odd terms drop\n\t\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalPhi]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], ",", 
             StyleBox["z", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["a", "TI"], "0"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], "2"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], "4"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "4"], "+", "\[Ellipsis]"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\Phi(r,z)\n=\na_0(z)\n+\na_2(z) r^2\n+\na_4(z) r^4\n+\\dots", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5566f821-ab19-4d61-8a04-f9dc3462b2cd"]
}], "Text",
 CellChangeTimes->{{3.981516222736751*^9, 
  3.981516278344963*^9}},ExpressionUUID->"20a96732-cff5-4023-b4b9-\
ab7604ca59ab"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"evenExpansion", " ", "=", " ", 
  RowBox[{"Normal", "[", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Phi]", "[", 
         RowBox[{"r", ",", "z"}], "]"}], " ", "+", 
        RowBox[{"\[Phi]", "[", 
         RowBox[{
          RowBox[{"-", "r"}], ",", "z"}], "]"}]}], ")"}], "/", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "4"}], "}"}]}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.981528572915297*^9, {3.981529832140568*^9, 3.9815298323236523`*^9}, {
   3.9816015768012533`*^9, 3.9816015768863487`*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"a938a638-e2b8-40d7-b5f7-7e203eebbca7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Phi]", "[", 
   RowBox[{"0", ",", "z"}], "]"}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   SuperscriptBox["r", "2"], " ", 
   RowBox[{
    SuperscriptBox["\[Phi]", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"2", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"0", ",", "z"}], "]"}]}], "+", 
  RowBox[{
   FractionBox["1", "24"], " ", 
   SuperscriptBox["r", "4"], " ", 
   RowBox[{
    SuperscriptBox["\[Phi]", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"4", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"0", ",", "z"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.981527059598566*^9, 3.9815285736173286`*^9, 
  3.981529832810927*^9, 3.9816015772100973`*^9},
 CellLabel->"Out[36]=",ExpressionUUID->"17a374a2-4988-404f-a403-6c796fad1c17"]
}, Open  ]],

Cell["\<\
Plugging this into Laplace\[CloseCurlyQuote]s equation, we can can relate \
radial derivatives to purely axial derivatives.\
\>", "Text",
 CellChangeTimes->{
  3.981529032815506*^9},ExpressionUUID->"251b1e7d-fcb8-46ae-a1ee-\
9e8e2dcf1678"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"evenLaplacian", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"Laplacian", "[", 
    RowBox[{"evenExpansion", ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "\[Theta]", ",", "z"}], "}"}], 
     ",", "\"\<Cylindrical\>\""}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"6b33702b-70e6-49dc-af7e-6a4056079cdc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[Phi]", 
    TagBox[
     RowBox[{"(", 
      RowBox[{"0", ",", "2"}], ")"}],
     Derivative],
    MultilineFunction->None], "[", 
   RowBox[{"0", ",", "z"}], "]"}], "+", 
  RowBox[{"2", " ", 
   RowBox[{
    SuperscriptBox["\[Phi]", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"2", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"0", ",", "z"}], "]"}]}], "+", 
  RowBox[{
   FractionBox["1", "24"], " ", 
   SuperscriptBox["r", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"12", " ", 
      RowBox[{
       SuperscriptBox["\[Phi]", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"2", ",", "2"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"0", ",", "z"}], "]"}]}], "+", 
     RowBox[{"16", " ", 
      RowBox[{
       SuperscriptBox["\[Phi]", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"4", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"0", ",", "z"}], "]"}]}], "+", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", 
      RowBox[{
       SuperscriptBox["\[Phi]", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"4", ",", "2"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"0", ",", "z"}], "]"}]}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.981529837560883*^9, 3.981601579587008*^9},
 CellLabel->"Out[37]=",ExpressionUUID->"4b986770-0502-4ea8-b2e9-e2d8feafdbe5"]
}, Open  ]],

Cell["\<\
To do this, we proceed recursively: matching the 1st order coefficients \
first, and substituting into higher-order ones.\
\>", "Text",
 CellChangeTimes->{{3.9815285807583*^9, 3.981528632326997*^9}, {
  3.9815286760871058`*^9, 3.981528691758497*^9}, {3.981528929715889*^9, 
  3.981528934004578*^9}, {3.981528974330791*^9, 
  3.981529034787834*^9}},ExpressionUUID->"5d5370ed-6f1e-40a1-aa8d-\
286c87a9a18c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"order0Substitutions", "=", 
   RowBox[{
    RowBox[{"Solve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{"evenLaplacian", ",", "r", ",", "0"}], "]"}], "==", "0"}], ",",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"2", ",", "0"}], "]"}], "[", "\[Phi]", "]"}], "[", 
