Cell["\<\
We can plot the rays by drawing straight-line segments between each breakpoint.
By convention, we draw the rays as propagating in the negative -z direction \
and, naturally, in green.\
\>", "Text",
 CellChangeTimes->{{3.9814486061595716`*^9, 3.98144860779869*^9}, {
  3.981448745160571*^9, 3.981448789017054*^9}, {3.981448888680554*^9, 
  3.9814489319439077`*^9}, {3.981448970724297*^9, 
  3.981448971902946*^9}},ExpressionUUID->"c54de771-9d67-44d9-ba51-\
828aec628297"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plotRays", "[", 
   RowBox[{"rays_", ",", "zStart_", ",", "zEnd_"}], "]"}], ":=", 
  RowBox[{"ListLinePlot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rays", "/.", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"z_", ",", 
        RowBox[{"{", 
         RowBox[{"r_", ",", "_"}], "}"}]}], "}"}], ":>", 
      RowBox[{"{", 
       RowBox[{"r", ",", 
        RowBox[{"-", "z"}]}], "}"}]}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "0.25"}], ",", "0.25"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "zStart"}], "+", "0.1"}], ",", 
         RowBox[{
          RowBox[{"-", "zEnd"}], "-", "0.1"}]}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"RGBColor", "[", 
      RowBox[{"0", ",", "0.5", ",", "0.0", ",", "0.5"}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"AspectRatio", "->", "2"}], ",", "\[IndentingNewLine]", 
    RowBox[{"FrameTicks", "->", "None"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotHighlighting", "->", "None"}], ",", "\[IndentingNewLine]", 
