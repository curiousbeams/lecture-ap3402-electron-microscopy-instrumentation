Cell["\<\
We can now use the parsed sequence to trace uniformly spaced rays inside the \
electron gun semiangle:\
\>", "Text",
 CellChangeTimes->{{3.981448487488286*^9, 
  3.98144852996027*^9}},ExpressionUUID->"afb64f68-0da8-4989-82c2-\
022547db7bfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"traceRaysOpticalSequence", "[", 
   RowBox[{
   "components_List", ",", "zStart_", ",", "zEnd_", ",", "semiangle_", ",", 
    RowBox[{"numRays_", ":", "128"}]}], "]"}], ":=", 
  RowBox[{"Block", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"opticalSequence", ",", "rays", ",", "graphics"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"opticalSequence", "=", 
      RowBox[{"parseOpticalSequence", "[", 
       RowBox[{"components", ",", "zStart", ",", "zEnd"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rays", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"traceRaySequence", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"Tan", "[", "\[Alpha]", "]"}]}], "}"}], ",", 
          "opticalSequence"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]", ",", 
          RowBox[{"Subdivide", "[", 
           RowBox[{
            RowBox[{"-", "semiangle"}], ",", "semiangle", ",", "numRays"}], 
           "]"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
     "\[IndentingNewLine]", "rays"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
