       RowBox[{"components", ",", 
        RowBox[{
         RowBox[{"#", "[", "\"\<axial_position\>\"", "]"}], "&"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"zPrev", "=", "zStart"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"comp", "[", "\"\<axial_position\>\"", "]"}], ">", 
           "zPrev"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"AppendTo", "[", "\[IndentingNewLine]", 
            RowBox[{"seq", ",", "\[IndentingNewLine]", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<type\>\"", "->", "\"\<propagation\>\""}], ",", 
               RowBox[{"\"\<dz\>\"", "->", 
                RowBox[{
                 RowBox[{"comp", "[", "\"\<axial_position\>\"", "]"}], "-", 
                 "zPrev"}]}]}], "|>"}]}], "\[IndentingNewLine]", "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"AppendTo", "[", 
         RowBox[{"seq", ",", "comp"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"zPrev", "=", 
         RowBox[{"comp", "[", "\"\<axial_position\>\"", "]"}]}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"comp", ",", "sorted"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"If", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zPrev", "<", "zEnd"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"seq", ",", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<type\>\"", "->", "\"\<propagation\>\""}], ",", 
            RowBox[{"\"\<dz\>\"", "->", 
             RowBox[{"zEnd", "-", "zPrev"}]}]}], "|>"}]}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "seq"}]}], "\[IndentingNewLine]", 
