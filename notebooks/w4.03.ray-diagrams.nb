Cell["\<\
This looks correct, but hard to understand the action of the lenses / \
apertures like this.
Let\[CloseCurlyQuote]s add them on the ray diagram using graphic primitives.\
\>", "Text",
 CellChangeTimes->{{3.981448975172608*^9, 
  3.9814490225689783`*^9}},ExpressionUUID->"42802042-872d-4c10-ba07-\
6c0d26998546"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"componentGraphics", ",", "singleComponentGraphics"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleComponentGraphics", "[", "\"\<sample\>\"", "]"}], "[", 
   RowBox[{"z_", ",", " ", 
    RowBox[{"width_", ":", "0.1"}], ",", 
    RowBox[{"thickness_", ":", "0.0075"}]}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"Rectangle", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "width"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"-", "z"}], "-", "thickness"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"width", "/", "2"}], ",", 
       RowBox[{
        RowBox[{"-", "z"}], "+", "thickness"}]}], "}"}]}], "]"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleComponentGraphics", "[", "\"\<lens\>\"", "]"}], "[", 
   RowBox[{"z_", ",", 
    RowBox[{"rx_", ":", "0.15"}], ",", 
    RowBox[{"ry_", ":", "0.0125"}]}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"Circle", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "z"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"rx", ",", "ry"}], "}"}]}], "]"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleComponentGraphics", "[", "\"\<aperture\>\"", "]"}], "[", 
   RowBox[{"z_", ",", "innerRadius_", ",", 
    RowBox[{"outerRadius_", ":", "0.15"}], ",", 
    RowBox[{"thickness_", ":", "0.0075"}]}], "]"}], ":=", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{"LightGray", ",", "\[IndentingNewLine]", 
    RowBox[{"Rectangle", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "outerRadius"}], ",", 
        RowBox[{
         RowBox[{"-", "z"}], "-", "thickness"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "innerRadius"}], ",", 
        RowBox[{
         RowBox[{"-", "z"}], "+", "thickness"}]}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Rectangle", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"innerRadius", ",", 
        RowBox[{
         RowBox[{"-", "z"}], "-", "thickness"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"outerRadius", ",", 
        RowBox[{
         RowBox[{"-", "z"}], "+", "thickness"}]}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"componentGraphics", "[", "element_", "]"}], ":=", 
  RowBox[{"Switch", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"element", "[", "\"\<type\>\"", "]"}], ",", 
    "\[IndentingNewLine]", "\"\<lens\>\"", ",", 
    RowBox[{
     RowBox[{"singleComponentGraphics", "[", "\"\<lens\>\"", "]"}], "[", 
     RowBox[{"element", "[", "\"\<axial_position\>\"", "]"}], "]"}], ",", 
    "\[IndentingNewLine]", "\"\<aperture\>\"", ",", 
    RowBox[{
     RowBox[{"singleComponentGraphics", "[", "\"\<aperture\>\"", "]"}], "[", 
     RowBox[{
      RowBox[{"element", "[", "\"\<axial_position\>\"", "]"}], ",", 
      RowBox[{"element", "[", "\"\<aperture_radius\>\"", "]"}]}], "]"}], ",", 
    "\[IndentingNewLine]", "\"\<sample\>\"", ",", 
    RowBox[{
     RowBox[{"singleComponentGraphics", "[", "\"\<sample\>\"", "]"}], "[", 
     RowBox[{"element", "[", "\"\<axial_position\>\"", "]"}], "]"}], ",", 
    "\[IndentingNewLine]", "_", ",", "Nothing"}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellLabel->"In[10]:=",ExpressionUUID->"92bcb6a1-5e6f-4eaa-afdb-0ebe1cb6309f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"computeAndShowRayDiagram", "[", 
   RowBox[{
   "components_List", ",", "zStart_", ",", "zEnd_", ",", "semiangle_", ",", 
    RowBox[{"numRays_", ":", "128"}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"rays", ",", "graphics"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rays", " ", "=", " ", 
      RowBox[{"traceRaysOpticalSequence", "[", 
       RowBox[{
       "components", ",", "zStart", ",", "zEnd", ",", "semiangle", ",", 
        "numRays"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"graphics", " ", "=", " ", 
      RowBox[{"Graphics", "[", 
       RowBox[{"componentGraphics", "/@", "components"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"plotRays", "[", 
        RowBox[{"rays", ",", "zStart", ",", "zEnd"}], "]"}], ",", 
       "\[IndentingNewLine]", "graphics"}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
